    private void OpenEditModal(AdminUserItem user)
    {
        _editingUser    = user;
        _formFirst      = user.FirstName;
        _formLast       = user.LastName;
        _formEmail      = user.Email;
        _formPhone      = user.Phone;
        _formRole       = char.ToUpper(user.Role[0]) + user.Role[1..];
        _formPassword   = _formConfirm = "";
        _modalError     = null;
        _modalSubmitted = false;
        _showUserModal  = true;
    }

    private void CloseUserModal() => _showUserModal = false;

    private async Task SaveUser()
    {
        _modalSubmitted = true;
        _modalError     = null;

        if (string.IsNullOrWhiteSpace(_formFirst) || string.IsNullOrWhiteSpace(_formLast)) return;
        if (_editingUser == null)
        {
            if (string.IsNullOrWhiteSpace(_formEmail)) return;
            if (!PasswordStrength.IsValid(_formPassword) || _formPassword != _formConfirm) return;
        }

        _modalSaving = true;
        try
        {
            if (_editingUser == null)
            {
                await AuthApi.AdminCreateUserAsync(new AdminCreateUserRequest
                {
                    FirstName = _formFirst, LastName = _formLast,
                    Email     = _formEmail, Password = _formPassword,
                    Phone     = _formPhone, Role     = _formRole
                });
                ShowToast("Usuario creado correctamente.");
            }
            else
            {
                await AuthApi.AdminUpdateUserAsync(_editingUser.Id, new AdminUpdateUserRequest
                {
                    FirstName = _formFirst, LastName = _formLast,
                    Phone     = _formPhone, Role     = _formRole
                });
                ShowToast("Usuario actualizado correctamente.");
            }
            CloseUserModal();
            await LoadUsers();
            await LoadStats();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            _modalError = "Ya existe un usuario con ese correo.";
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally { _modalSaving = false; }
    }

