@page "/admin"
@attribute [Authorize]
@inject AuthApiClient             AuthApi
@inject PatientApiClient          PatientApi
@inject AppointmentApiClient      AppointmentApi
@inject ConsultationLogApiClient  LogApi
@inject SpeciesApiClient          SpeciesApi
@inject TokenProvider             Token
@inject NavigationManager         Nav

<PageTitle>Administración — VetSystem</PageTitle>

<div class="page-header">
    <div class="page-title">⚙️ Panel de administración</div>
    <div class="page-subtitle">Vista global del sistema</div>
</div>

<div class="page-content">

    @* ── KPIs — cambian según la tab activa ── *@
    <div class="stats-row">
        @if (_tab == "users")
        {
            <div class="stat-card">
                <div class="stat-label">Total usuarios</div>
                <div class="stat-value">@_totalUsers</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Usuarios activos</div>
                <div class="stat-value" style="color:var(--color-success)">@_activeUsers</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Usuarios inactivos</div>
                <div class="stat-value" style="color:var(--color-danger)">@_inactiveUsers</div>
            </div>
        }
        else if (_tab == "patients")
        {
            <div class="stat-card">
                <div class="stat-label">Total mascotas</div>
                <div class="stat-value">@(_patientStatsLoaded ? _statPatientsTotal.ToString() : "…")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Machos</div>
                <div class="stat-value" style="color:#3b82f6">@(_patientStatsLoaded ? _statPatientsMale.ToString() : "…")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Hembras</div>
                <div class="stat-value" style="color:#ec4899">@(_patientStatsLoaded ? _statPatientsFemale.ToString() : "…")</div>
            </div>
        }
        else if (_tab == "appointments")
        {
            <div class="stat-card">
                <div class="stat-label">Total citas</div>
                <div class="stat-value">@(_apptStatsLoaded ? _statApptsTotal.ToString() : "…")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Pendientes</div>
                <div class="stat-value" style="color:var(--color-warning)">@(_apptStatsLoaded ? _statApptsPending.ToString() : "…")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Completadas</div>
                <div class="stat-value" style="color:var(--color-success)">@(_apptStatsLoaded ? _statApptsCompleted.ToString() : "…")</div>
            </div>
        }
        else if (_tab == "species")
        {
            <div class="stat-card">
                <div class="stat-label">Total especies</div>
                <div class="stat-value">@_speciesList.Count</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Con mascotas</div>
                <div class="stat-value" style="color:var(--color-success)">@_speciesList.Count(s => s.PatientCount > 0)</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Sin mascotas</div>
                <div class="stat-value" style="color:var(--color-text-muted)">@_speciesList.Count(s => s.PatientCount == 0)</div>
            </div>
        }
        else if (_tab == "schedules" && _clinicSettings is not null)
        {
            <div class="stat-card">
                <div class="stat-label">Horario clínica</div>
                <div class="stat-value" style="font-size:1rem">@_clinicSettings.StartTime – @_clinicSettings.EndTime</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Días laborables</div>
                <div class="stat-value">@_clinicSettings.WorkDays.Count</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Overrides de vet</div>
                <div class="stat-value">@_vetSchedules.Count</div>
            </div>
        }
    </div>

    @* ── Tabs ── *@
    <div class="admin-tabs">
        <button class="admin-tab @(_tab == "users" ? "active" : "")" @onclick='() => SwitchTab("users")'>
            👥 Usuarios
        </button>
        <button class="admin-tab @(_tab == "patients" ? "active" : "")" @onclick='() => SwitchTab("patients")'>
            🐾 Mascotas
        </button>
        <button class="admin-tab @(_tab == "appointments" ? "active" : "")" @onclick='() => SwitchTab("appointments")'>
            📅 Citas
        </button>
        <button class="admin-tab @(_tab == "species" ? "active" : "")" @onclick='() => SwitchTab("species")'>
            🐾 Especies
        </button>
        <button class="admin-tab @(_tab == "schedules" ? "active" : "")" @onclick='() => SwitchTab("schedules")'>
            🕐 Horarios
        </button>
    </div>

    @* ═══════════════════════════════════════════════
       TAB: USUARIOS
       ═══════════════════════════════════════════════ *@
    @if (_tab == "users")
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Usuarios</span>
                <div class="filters-bar mb-0">
                    <button class="btn btn-primary btn-sm" @onclick="OpenCreateModal">+ Nuevo usuario</button>
                    <div class="search-input" style="min-width:200px">
                        <span class="search-icon">🔍</span>
                        <input class="form-control" placeholder="Buscar por nombre o correo…"
                               value="@_search" @oninput="HandleSearchInput" />
                    </div>
                    <select class="filter-select" @bind="_roleFilter" @bind:after="ReloadUsers">
                        <option value="">Todos los roles</option>
                        <option value="Owner">Propietarios</option>
                        <option value="Veterinarian">Veterinarios</option>
                        <option value="Admin">Administradores</option>
                    </select>
                    <select class="filter-select" @bind="_activeFilter" @bind:after="ReloadUsers">
                        <option value="">Todos los estados</option>
                        <option value="true">Activos</option>
                        <option value="false">Inactivos</option>
                    </select>
                </div>
            </div>

            <div class="table-wrapper">
                @if (_usersLoading)
                {
                    <div class="loading-pad"><LoadingSpinner Message="Cargando usuarios…" /></div>
                }
                else if (_users.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">👥</div>
                        <div class="empty-state-title">Sin resultados</div>
                        <div class="empty-state-sub">No hay usuarios para los filtros seleccionados.</div>
                    </div>
                }
                else
                {
                    <table class="vet-table">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Teléfono</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Registrado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                var user = u;
                                <tr style="@(user.IsActive ? "" : "opacity:.6")">
                                    <td data-label="Nombre"><strong>@user.FullName</strong></td>
                                    <td data-label="Correo" style="font-size:.85rem">@user.Email</td>
                                    <td data-label="Teléfono" style="font-size:.85rem">@(string.IsNullOrEmpty(user.Phone) ? "—" : user.Phone)</td>
                                    <td data-label="Rol"><span class="role-badge role-@user.Role.ToLower()">@RoleLabel(user.Role)</span></td>
                                    <td data-label="Estado">
                                        @if (user.IsActive)
                                        { <span class="badge badge-confirmed">Activo</span> }
                                        else
                                        { <span class="badge badge-cancelled">Inactivo</span> }
                                    </td>
                                    <td data-label="Registrado" style="font-size:.8rem">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Acciones" class="td-actions">
                                        @{ var isSelf = Token.User != null && user.Id == Token.User.Id; }
                                        <span class="tip-wrap">
                                            <button class="btn btn-sm btn-icon-edit"
                                                    @onclick="() => OpenEditModal(user)">✏️</button>
                                            <span class="tip-txt">Editar usuario</span>
                                        </span>
                                        @if (user.IsActive)
                                        {
                                            <span class="tip-wrap">
                                                <button class="btn btn-sm btn-icon-deact"
                                                        style="@(isSelf ? "opacity:.4;cursor:not-allowed;" : "")"
                                                        disabled="@isSelf"
                                                        @onclick="() => ToggleActive(user)">⏸</button>
                                                <span class="tip-txt">@(isSelf ? "No puedes desactivar tu propia cuenta" : "Desactivar usuario")</span>
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="tip-wrap">
                                                <button class="btn btn-sm btn-icon-activate"
                                                        @onclick="() => ToggleActive(user)">▶</button>
                                                <span class="tip-txt">Activar usuario</span>
                                            </span>
                                        }
                                        <span class="tip-wrap">
                                            <button class="btn btn-sm btn-icon-reset"
                                                    @onclick="() => OpenResetModal(user)">🔑</button>
                                            <span class="tip-txt">Resetear contraseña</span>
                                        </span>
                                        <span class="tip-wrap">
                                            <button class="btn btn-sm btn-icon-delete"
                                                    style="@(isSelf ? "opacity:.4;cursor:not-allowed;" : "")"
                                                    disabled="@isSelf"
                                                    @onclick="() => OpenDeleteUserConfirm(user)">🗑️</button>
                                            <span class="tip-txt">@(isSelf ? "No puedes eliminar tu propia cuenta" : "Eliminar usuario")</span>
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (_usersTotal > _usersPageSize)
                    {
                        <div class="pagination pagination-padded">
                            <button class="page-btn" disabled="@(_usersPage == 1)" @onclick="UsersPrevPage">‹</button>
                            <span class="page-btn active">@_usersPage / @UsersTotalPages</span>
                            <button class="page-btn" disabled="@(_usersPage >= UsersTotalPages)" @onclick="UsersNextPage">›</button>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════
       TAB: MASCOTAS
       ═══════════════════════════════════════════════ *@
    @if (_tab == "patients")
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Todas las mascotas</span>
                <div class="card-header-actions">
                    <button class="btn btn-primary btn-sm" @onclick="() => _showVetPatientModal = true">+ Registrar mascota</button>
                    <div class="filters-bar mb-0">
                        <div class="search-input" style="min-width:200px">
                            <span class="search-icon">🔍</span>
                            <input class="form-control" placeholder="Buscar por nombre…"
                                   value="@_patientsSearch" @oninput="HandlePatientsSearch" />
                        </div>
                        <select class="filter-select" @bind="_patientsSpecies" @bind:after="ReloadPatients">
                            <option value="">Todas las especies</option>
                            @foreach (var s in _speciesList)
                            {
                                <option value="@s.Slug">@s.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-body" style="padding:0">
                @if (_patientsLoading)
                {
                    <div class="loading-pad"><LoadingSpinner Message="Cargando mascotas…" /></div>
                }
                else if (_patients.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🐾</div>
                        <div class="empty-state-title">Sin resultados</div>
                        <div class="empty-state-sub">No hay mascotas registradas con esos filtros.</div>
                    </div>
                }
                else
                {
                    <div class="grid-pad">
                        <div class="patients-grid">
                            @foreach (var p in _patients)
                            {
                                <PatientCard Patient="p"
                                             OnSelect="EventCallback.Factory.Create(this, () => OpenEditPatient(p))" />
                            }
                        </div>
                        @if (_patientsTotal > _patientsPageSize)
                        {
                            <div class="pagination">
                                <button class="page-btn" disabled="@(_patientsPage == 1)" @onclick="PatientsPrevPage">‹</button>
                                <span class="page-btn active">@_patientsPage / @PatientsTotalPages</span>
                                <span style="font-size:.8rem;color:var(--color-text-muted);margin-left:4px">(@_patientsTotal total)</span>
                                <button class="page-btn" disabled="@(_patientsPage >= PatientsTotalPages)" @onclick="PatientsNextPage">›</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════
       TAB: CITAS
       ═══════════════════════════════════════════════ *@
    @if (_tab == "appointments")
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Todas las citas</span>
                <div class="card-header-actions">
                    <button class="btn btn-primary btn-sm" @onclick="() => _showNewAppointmentModal = true">+ Nueva cita</button>
                    <div class="filters-bar mb-0">
                        <select class="filter-select" @bind="_apptsStatus" @bind:after="ReloadAppointments">
                            <option value="">Todos los estados</option>
                            <option value="Scheduled">Programadas</option>
                            <option value="Confirmed">Confirmadas</option>
                            <option value="Completed">Completadas</option>
                            <option value="Cancelled">Canceladas</option>
                            <option value="NoShow">No asistió</option>
                        </select>
                        <label class="date-filter-label">
                            <span>Desde</span>
                            <input type="date" class="filter-select" @bind="_apptsFrom" @bind:after="ReloadAppointments" />
                        </label>
                        <label class="date-filter-label">
                            <span>Hasta</span>
                            <input type="date" class="filter-select" @bind="_apptsTo" @bind:after="ReloadAppointments" />
                        </label>
                    </div>
                </div>
            </div>

            <div class="table-wrapper">
                @if (_apptsLoading)
                {
                    <div class="loading-pad"><LoadingSpinner Message="Cargando citas…" /></div>
                }
                else if (_appointments.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">📅</div>
                        <div class="empty-state-title">Sin resultados</div>
                        <div class="empty-state-sub">No hay citas con los filtros seleccionados.</div>
                    </div>
                }
                else
                {
                    <table class="vet-table">
                        <thead>
                            <tr>
                                <th>Paciente / Propietario</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Duración</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _appointments)
                            {
                                <AppointmentCard Appointment="a"
                                                 ShowActions="true"
                                                 OnStatusChange="HandleStatusChange"
                                                 OnOpenLog="EventCallback.Factory.Create<AppointmentResponse>(this, OpenAppointmentLog)" />
                            }
                        </tbody>
                    </table>

                    @if (_apptsTotal > _apptsPageSize)
                    {
                        <div class="pagination pagination-padded">
                            <button class="page-btn" disabled="@(_apptsPage == 1)" @onclick="ApptsPrevPage">‹</button>
                            <span class="page-btn active">@_apptsPage / @ApptsTotalPages</span>
                            <span style="font-size:.8rem;color:var(--color-text-muted);margin-left:4px">(@_apptsTotal total)</span>
                            <button class="page-btn" disabled="@(_apptsPage >= ApptsTotalPages)" @onclick="ApptsNextPage">›</button>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════
       TAB: ESPECIES
       ═══════════════════════════════════════════════ *@
    @if (_tab == "species")
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Especies</span>
                <button class="btn btn-primary btn-sm" @onclick="OpenNewSpecies">+ Nueva especie</button>
            </div>

            @if (!string.IsNullOrEmpty(_speciesError))
            { <div class="alert alert-danger" style="margin:16px 20px 0">⚠️ @_speciesError</div> }

            @if (_speciesLoading)
            {
                <div class="loading-pad"><LoadingSpinner Message="Cargando especies…" /></div>
            }
            else
            {
                @if (_showNewSpeciesForm)
                {
                    <div style="padding:16px 20px;border-bottom:1px solid var(--color-border);background:var(--color-surface-alt)">
                        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                            <div class="icon-dropdown-wrap">
                                <button type="button" class="icon-dropdown-trigger"
                                        @onclick="() => _newIconPickerOpen = !_newIconPickerOpen">
                                    <span>@_newSpeciesIcon</span>
                                    <span class="icon-dropdown-arrow">▾</span>
                                </button>
                                @if (_newIconPickerOpen)
                                {
                                    <div class="icon-dropdown-backdrop" @onclick="() => _newIconPickerOpen = false"></div>
                                    <div class="icon-dropdown-panel">
                                        @foreach (var e in AvailableIcons)
                                        {
                                            var icon = e;
                                            <button type="button"
                                                    class="emoji-option @(_newSpeciesIcon == icon ? "selected" : "")"
                                                    @onclick="() => { _newSpeciesIcon = icon; _newIconPickerOpen = false; }">@icon</button>
                                        }
                                    </div>
                                }
                            </div>
                            <input class="form-control @(_speciesSubmitted && string.IsNullOrWhiteSpace(_newSpeciesName) ? "invalid" : "")"
                                   style="flex:1;min-width:180px;max-width:320px"
                                   placeholder="Nombre de la especie (ej. Tortuga)"
                                   @bind="_newSpeciesName" @bind:event="oninput" />
                            <button class="btn btn-primary btn-sm" @onclick="SaveNewSpecies" disabled="@_speciesSaving">
                                @if (_speciesSaving) { <span class="spinner spinner-sm"></span> }
                                else { <span>Guardar</span> }
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="CancelNewSpecies">Cancelar</button>
                        </div>
                        @if (_speciesSubmitted && string.IsNullOrWhiteSpace(_newSpeciesName))
                        { <div class="validation-message" style="margin-top:6px">El nombre es obligatorio.</div> }
                    </div>
                }

                <div class="table-wrapper">
                    @if (_speciesList.Count == 0)
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">🐾</div>
                            <div class="empty-state-title">Sin especies</div>
                            <div class="empty-state-sub">Agrega la primera especie con el botón de arriba.</div>
                        </div>
                    }
                    else
                    {
                        <table class="vet-table">
                            <thead>
                                <tr>
                                    <th>Especie</th>
                                    <th style="text-align:center">Mascotas</th>
                                    <th>Creada</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int _spIdx = 0; }
                                @foreach (var s in _speciesList)
                                {
                                    var sp = s;
                                    bool _dropUp = (_spIdx++ >= _speciesList.Count - 2);
                                    <tr>
                                        <td data-label="Especie">
                                            @if (_editingSpeciesId == sp.Id)
                                            {
                                                <div style="display:flex;gap:8px;align-items:center">
                                                    <div class="icon-dropdown-wrap">
                                                        <button type="button" class="icon-dropdown-trigger"
                                                                @onclick="() => _editIconPickerOpen = !_editIconPickerOpen">
                                                            <span>@_editSpeciesIcon</span>
                                                            <span class="icon-dropdown-arrow">▾</span>
                                                        </button>
                                                        @if (_editIconPickerOpen)
                                                        {
                                                            <div class="icon-dropdown-backdrop" @onclick="() => _editIconPickerOpen = false"></div>
                                                            <div class="icon-dropdown-panel @(_dropUp ? "drop-up" : "")">
                                                                @foreach (var e in AvailableIcons)
                                                                {
                                                                    var icon = e;
                                                                    <button type="button"
                                                                            class="emoji-option @(_editSpeciesIcon == icon ? "selected" : "")"
                                                                            @onclick="() => { _editSpeciesIcon = icon; _editIconPickerOpen = false; }">@icon</button>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <input class="form-control"
                                                           style="max-width:200px"
                                                           @bind="_editSpeciesName" @bind:event="oninput" />
                                                </div>
                                            }
                                            else
                                            {
                                                <strong>@sp.Icon @sp.Name</strong>
                                            }
                                        </td>
                                        <td data-label="Mascotas">
                                            @if (sp.PatientCount > 0)
                                            { <span class="badge badge-confirmed">@sp.PatientCount</span> }
                                            else
                                            { <span style="color:var(--color-text-muted)">0</span> }
                                        </td>
                                        <td data-label="Creada" style="font-size:.8rem">@sp.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td data-label="Acciones" class="td-actions">
                                            @if (_editingSpeciesId == sp.Id)
                                            {
                                                <button class="btn btn-sm btn-icon-save"
                                                        @onclick="() => SaveEditSpecies(sp.Id)"
                                                        disabled="@_speciesSaving">
                                                    @if (_speciesSaving) { <span class="spinner spinner-sm"></span> }
                                                    else { <span>✓</span> }
                                                </button>
                                                <button class="btn btn-sm btn-ghost" @onclick="CancelEditSpecies">✕</button>
                                            }
                                            else
                                            {
                                                <span class="tip-wrap">
                                                    <button class="btn btn-sm btn-icon-edit"
                                                            @onclick="() => StartEditSpecies(sp)">✏️</button>
                                                    <span class="tip-txt">Editar especie</span>
                                                </span>
                                                <span class="tip-wrap">
                                                    <button class="btn btn-sm btn-icon-delete"
                                                            style="@(sp.PatientCount > 0 ? "opacity:.4;cursor:not-allowed;" : "")"
                                                            disabled="@(sp.PatientCount > 0)"
                                                            @onclick="() => DeleteSpecies(sp.Id)">🗑️</button>
                                                    <span class="tip-txt">@(sp.PatientCount > 0 ? $"Hay {sp.PatientCount} mascota(s) asignada(s) — no se puede eliminar" : "Eliminar especie")</span>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </div>
    }

    @* ═══════════════════════════════════════════════
       TAB: HORARIOS
       ═══════════════════════════════════════════════ *@
    @if (_tab == "schedules")
    {
        @* ── Configuración global de la clínica ── *@
        <div class="card" style="margin-bottom:1.5rem">
            <div class="card-header">
                <span class="card-title">Horario global de la clínica</span>
            </div>
            @if (_schedulesLoading)
            {
                <div class="loading-pad"><LoadingSpinner Message="Cargando horarios…" /></div>
            }
            else
            {
                <div style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem">
                    <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end">
                        <div>
                            <label class="form-label">Hora inicio</label>
                            <input type="time" class="form-control" style="width:120px"
                                   @bind="_editStart" />
                        </div>
                        <div>
                            <label class="form-label">Hora fin</label>
                            <input type="time" class="form-control" style="width:120px"
                                   @bind="_editEnd" />
                        </div>
                        <div style="flex:1;min-width:220px">
                            <label class="form-label">Días laborables</label>
                            <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.25rem">
                                @foreach (var day in AllDays)
                                {
                                    var d = day;
                                    var sel = _editWorkDays.Contains(d);
                                    <button type="button"
                                            style="cursor:pointer;padding:4px 10px;border-radius:6px;font-size:.8rem;font-weight:500;border:1.5px solid @(sel ? "var(--color-primary)" : "var(--color-border)");background:@(sel ? "var(--color-primary)" : "transparent");color:@(sel ? "#fff" : "var(--color-text-secondary)");"
                                            @onclick="() => ToggleWorkDay(d)">
                                        @DayLabel(d)
                                    </button>
                                }
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-primary btn-sm" @onclick="SaveClinicSettings"
                                    disabled="@_schedulesSaving">
                                @(_schedulesSaving ? "Guardando…" : "Guardar")
                            </button>
                        </div>
                    </div>
                    @if (_schedulesError is not null)
                    {
                        <div class="alert alert-danger mb-0">@_schedulesError</div>
                    }
                </div>
            }
        </div>

        @* ── Horarios personalizados por veterinario ── *@
        <div class="card" style="margin-bottom:1.5rem">
            <div class="card-header">
                <span class="card-title">Horario personalizado por veterinario</span>
            </div>
            <div style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem">
                <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap">
                    <div style="flex:1;min-width:200px">
                        <label class="form-label">Veterinario</label>
                        <select class="filter-select" style="width:100%" @bind="_schedVetId" @bind:after="LoadVetSchedules">
                            <option value="">— Selecciona —</option>
                            @foreach (var u in _vets)
                            {
                                <option value="@u.Id">@u.FullName</option>
                            }
                        </select>
                    </div>
                </div>

                @if (_schedVetId != Guid.Empty)
                {
                    @if (_vetSchedules.Count > 0)
                    {
                        <div style="display:flex;flex-direction:column;gap:0.5rem">
                            @foreach (var s in _vetSchedules)
                            {
                                var sc = s;
                                <div style="display:flex;align-items:center;justify-content:space-between;
                                            padding:0.6rem 0.875rem;border-radius:8px;
                                            background:var(--color-surface-alt);border:1px solid var(--color-border)">
                                    <div style="display:flex;align-items:center;gap:1rem">
                                        <span style="font-weight:600;font-size:.875rem;min-width:36px">@DayLabel(sc.DayOfWeek)</span>
                                        <span style="font-size:.875rem;color:var(--color-text-secondary)">@sc.StartTime – @sc.EndTime</span>
                                    </div>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteVetSchedule(sc.DayOfWeek)">
                                        Eliminar
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="color:var(--color-text-muted);font-size:0.875rem">
                            Este veterinario no tiene horario personalizado. Usa el horario global para todos los días.
                        </p>
                    }

                    <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap;border-top:1px solid var(--color-border);padding-top:0.75rem">
                        <div>
                            <label class="form-label">Día</label>
                            <select class="filter-select" @bind="_newSchedDay">
                                @foreach (var day in AllDays)
                                {
                                    <option value="@day">@DayLabel(day)</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Inicio</label>
                            <input type="time" class="form-control" style="width:110px" @bind="_newSchedStart" />
                        </div>
                        <div>
                            <label class="form-label">Fin</label>
                            <input type="time" class="form-control" style="width:110px" @bind="_newSchedEnd" />
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="UpsertVetSchedule"
                                disabled="@_schedulesSaving">
                            @(_schedulesSaving ? "…" : "Guardar override")
                        </button>
                    </div>
                }
            </div>
        </div>

        @* ── Permisos / Ausencias ── *@
        <div class="card">
            <div class="card-header">
                <span class="card-title">Ausencias y permisos</span>
            </div>
            <div style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem">
                <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap">
                    <div style="flex:1;min-width:200px">
                        <label class="form-label">Veterinario</label>
                        <select class="filter-select" style="width:100%" @bind="_leaveVetId" @bind:after="LoadVetLeaves">
                            <option value="">— Selecciona —</option>
                            @foreach (var u in _vets)
                            {
                                <option value="@u.Id">@u.FullName</option>
                            }
                        </select>
                    </div>
                </div>

                @if (_leaveVetId != Guid.Empty)
                {
                    @if (_vetLeaves.Count > 0)
                    {
                        <div style="display:flex;flex-direction:column;gap:0.5rem">
                            @foreach (var l in _vetLeaves)
                            {
                                var lv = l;
                                <div style="display:flex;align-items:center;justify-content:space-between;
                                            padding:0.6rem 0.875rem;border-radius:8px;
                                            background:var(--color-surface-alt);border:1px solid var(--color-border)">
                                    <div style="display:flex;flex-direction:column;gap:2px">
                                        <div style="font-size:.875rem">
                                            <span style="font-weight:600">@lv.DateFrom</span>
                                            @if (lv.DateTo != lv.DateFrom)
                                            {
                                                <span style="color:var(--color-text-muted)"> → </span>
                                                <span style="font-weight:600">@lv.DateTo</span>
                                            }
                                            @if (lv.StartTime is not null)
                                            {
                                                <span style="margin-left:8px;color:var(--color-text-secondary);font-size:.82rem">
                                                    @lv.StartTime – @lv.EndTime
                                                </span>
                                            }
                                        </div>
                                        <div style="font-size:.8rem;color:var(--color-text-muted)">@lv.Reason</div>
                                    </div>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteVetLeave(lv.Id)">
                                        Eliminar
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="color:var(--color-text-muted);font-size:0.875rem">Sin ausencias registradas.</p>
                    }

                    <div style="border-top:1px solid var(--color-border);padding-top:0.75rem;display:flex;flex-direction:column;gap:0.75rem">
                        <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap">
                            <div>
                                <label class="form-label">Desde</label>
                                <input type="date" class="form-control" style="width:150px"
                                       value="@_newLeaveFrom"
                                       @onchange="e => { _newLeaveFrom = e.Value?.ToString() ?? _newLeaveFrom; if (_leavePartial) _newLeaveTo = _newLeaveFrom; }" />
                            </div>
                            <div>
                                <label class="form-label">Hasta</label>
                                <input type="date" class="form-control" style="width:150px"
                                       value="@_newLeaveTo"
                                       disabled="@_leavePartial"
                                       @onchange="e => _newLeaveTo = e.Value?.ToString() ?? _newLeaveTo" />
                            </div>
                            <div style="flex:1;min-width:200px">
                                <label class="form-label">Motivo</label>
                                <input type="text" class="form-control" @bind="_newLeaveReason" placeholder="Ej: Vacaciones, permiso médico…" />
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:0.5rem">
                            <input type="checkbox" id="leavePartialChk" @bind="_leavePartial"
                                   @bind:after="OnLeavePartialToggled" />
                            <label for="leavePartialChk" style="font-size:.875rem;cursor:pointer">
                                Ausencia parcial (solo un rango horario del día)
                            </label>
                        </div>
                        @if (_leavePartial)
                        {
                            <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap;padding-left:1.5rem">
                                <div>
                                    <label class="form-label">Hora inicio</label>
                                    <input type="time" class="form-control" style="width:130px"
                                           value="@_newLeaveStart"
                                           @onchange="e => _newLeaveStart = e.Value?.ToString() ?? _newLeaveStart" />
                                </div>
                                <div>
                                    <label class="form-label">Hora fin</label>
                                    <input type="time" class="form-control" style="width:130px"
                                           value="@_newLeaveEnd"
                                           @onchange="e => _newLeaveEnd = e.Value?.ToString() ?? _newLeaveEnd" />
                                </div>
                            </div>
                        }
                        <div>
                            <button class="btn btn-primary btn-sm" @onclick="CreateVetLeave"
                                    disabled="@_leavesSaving">
                                @(_leavesSaving ? "…" : "Registrar ausencia")
                            </button>
                        </div>
                    </div>
                    @if (_leavesError is not null)
                    {
                        <div class="alert alert-danger mb-0">@_leavesError</div>
                    }
                }
            </div>
        </div>
    }

</div>

@* ── Modal crear/editar usuario ── *@
@if (_showUserModal)
{
    <div class="modal-overlay">
        <div class="modal-box" tabindex="-1" @ref="_userModalRef" @onkeydown="HandleModalKey" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(_editingUser == null ? "➕ Nuevo usuario" : "✏️ Editar usuario")</span>
                <button class="btn-close" @onclick="CloseUserModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_modalError))
                { <div class="alert alert-danger">⚠️ @_modalError</div> }

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control @ModalCls(_formFirst)"
                               @bind="_formFirst" placeholder="Nombre" />
                        @if (_modalSubmitted && string.IsNullOrWhiteSpace(_formFirst))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Apellido *</label>
                        <input class="form-control @ModalCls(_formLast)"
                               @bind="_formLast" placeholder="Apellido" />
                        @if (_modalSubmitted && string.IsNullOrWhiteSpace(_formLast))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                </div>

                @if (_editingUser == null)
                {
                    <div class="form-group">
                        <label class="form-label">Correo electrónico *</label>
                        <input type="email" class="form-control @ModalCls(_formEmail)"
                               @bind="_formEmail" placeholder="correo@ejemplo.com" />
                        @if (_modalSubmitted && string.IsNullOrWhiteSpace(_formEmail))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                }

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Teléfono</label>
                        <PhoneInput @bind-Value="_formPhone" Placeholder="3001234567" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Rol *</label>
                        <select class="form-control" @bind="_formRole">
                            <option value="Owner">Propietario</option>
                            <option value="Veterinarian">Veterinario</option>
                            <option value="Admin">Administrador</option>
                        </select>
                    </div>
                </div>

                @if (_editingUser == null)
                {
                    <div class="form-group">
                        <label class="form-label">Contraseña *</label>
                        <input type="password"
                               class="form-control @(_modalSubmitted && !PasswordStrength.IsValid(_formPassword) ? "invalid" : "")"
                               value="@_formPassword"
                               @oninput="e => _formPassword = e.Value?.ToString() ?? string.Empty"
                               placeholder="Mínimo 8 caracteres" />
                        <PasswordStrength Password="@_formPassword" />
                        @if (_modalSubmitted && !PasswordStrength.IsValid(_formPassword))
                        { <div class="validation-message">La contraseña no cumple los requisitos.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirmar contraseña *</label>
                        <input type="password"
                               class="form-control @(!string.IsNullOrEmpty(_formConfirm) && _formConfirm != _formPassword ? "invalid" : "")"
                               value="@_formConfirm"
                               @oninput="e => _formConfirm = e.Value?.ToString() ?? string.Empty"
                               placeholder="Repite la contraseña" />
                        <PasswordMatchHint Password="@_formPassword" Confirm="@_formConfirm" />
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseUserModal" disabled="@_modalSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveUser" disabled="@_modalSaving">
                    @if (_modalSaving) { <span class="spinner spinner-sm"></span> }
                    else { <span>@(_editingUser == null ? "Crear usuario" : "Guardar cambios")</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ── Modal resetear contraseña ── *@
@if (_showResetModal)
{
    <div class="modal-overlay">
        <div class="modal-box" style="max-width:420px" tabindex="-1" @ref="_resetModalRef" @onkeydown="HandleResetKey" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">🔑 Resetear contraseña</span>
                <button class="btn-close" @onclick="() => _showResetModal = false">✕</button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom:12px;color:var(--color-text-muted);font-size:.9rem">
                    Usuario: <strong>@_resetTargetName</strong>
                </p>
                @if (!string.IsNullOrEmpty(_resetError))
                { <div class="alert alert-danger">⚠️ @_resetError</div> }
                <div class="form-group">
                    <label class="form-label">Nueva contraseña *</label>
                    <input type="password"
                           class="form-control @(_resetSubmitted && !PasswordStrength.IsValid(_resetPassword) ? "invalid" : "")"
                           value="@_resetPassword"
                           @oninput="e => _resetPassword = e.Value?.ToString() ?? string.Empty"
                           placeholder="Mínimo 8 caracteres" />
                    <PasswordStrength Password="@_resetPassword" />
                    @if (_resetSubmitted && !PasswordStrength.IsValid(_resetPassword))
                    { <div class="validation-message">La contraseña no cumple los requisitos.</div> }
                </div>
                <div class="form-group">
                    <label class="form-label">Confirmar *</label>
                    <input type="password"
                           class="form-control @(!string.IsNullOrEmpty(_resetConfirm) && _resetConfirm != _resetPassword ? "invalid" : "")"
                           value="@_resetConfirm"
                           @oninput="e => _resetConfirm = e.Value?.ToString() ?? string.Empty"
                           placeholder="Repite la contraseña" />
                    <PasswordMatchHint Password="@_resetPassword" Confirm="@_resetConfirm" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showResetModal = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="DoResetPassword" disabled="@_resetSaving">
                    @if (_resetSaving) { <span class="spinner spinner-sm"></span> }
                    else { <span>Confirmar</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ── Modal confirmación eliminar usuario ── *@
@if (_showDeleteUserConfirm)
{
    <div class="modal-overlay">
        <div class="modal-box" style="max-width:420px" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">🗑️ Eliminar usuario</span>
                <button class="btn-close" @onclick="() => _showDeleteUserConfirm = false">✕</button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom:8px">¿Eliminar a <strong>@_deleteUserTarget?.FullName</strong>?</p>
                <p style="color:var(--color-text-muted);font-size:.875rem">
                    Esta acción también eliminará todas sus mascotas del sistema. No se perderán datos — es un borrado suave.
                </p>
                @if (!string.IsNullOrEmpty(_deleteUserError))
                { <div class="alert alert-danger" style="margin-top:12px">⚠️ @_deleteUserError</div> }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showDeleteUserConfirm = false" disabled="@_deleteUserSaving">Cancelar</button>
                <button class="btn btn-danger" @onclick="ConfirmDeleteUser" disabled="@_deleteUserSaving">
                    @if (_deleteUserSaving) { <span class="spinner spinner-sm"></span> }
                    else { <span>Eliminar</span> }
