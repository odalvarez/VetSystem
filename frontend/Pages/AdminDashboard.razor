        }

        var uri = new Uri(Nav.Uri);
        var qs  = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tab = qs["tab"] ?? "users";
        _tab = tab is "users" or "patients" or "appointments" or "species" or "schedules" ? tab : "users";

        var tasks = new List<Task> { LoadUsers(), LoadStats(), LoadSpecies() };
        if (_tab == "patients")    { tasks.Add(LoadPatients()); tasks.Add(LoadPatientStats()); }
        if (_tab == "appointments"){ tasks.Add(LoadAppointments()); tasks.Add(LoadApptStats()); }
        if (_tab == "schedules")   tasks.Add(LoadSchedulesTab());
        await Task.WhenAll(tasks);
    }

    private async Task SwitchTab(string tab)
    {
        if (_tab == tab) return;
        _tab = tab;
        Nav.NavigateTo($"/admin?tab={tab}", replace: true);
        if (tab == "patients")
        {
            var tasks = new List<Task>();
            if (_patients.Count == 0 && !_patientsLoading) tasks.Add(LoadPatients());
            if (!_patientStatsLoaded)                      tasks.Add(LoadPatientStats());
            if (tasks.Any()) await Task.WhenAll(tasks);
        }
        else if (tab == "appointments")
        {
            var tasks = new List<Task>();
            if (_appointments.Count == 0 && !_apptsLoading) tasks.Add(LoadAppointments());
            if (!_apptStatsLoaded)                          tasks.Add(LoadApptStats());
            if (tasks.Any()) await Task.WhenAll(tasks);
        }
        else if (tab == "species" && _speciesList.Count == 0 && !_speciesLoading)
            await LoadSpecies();
        else if (tab == "schedules" && _clinicSettings is null)
            await LoadSchedulesTab();
    }

