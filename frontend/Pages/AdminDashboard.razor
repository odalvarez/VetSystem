    private async Task ConfirmDeleteUser()
    {
        if (_deleteUserTarget is null) return;
        _deleteUserSaving = true;
        _deleteUserError  = null;
        try
        {
            // Primero soft-delete de todas las mascotas del usuario
            await PatientApi.DeleteByOwnerAsync(_deleteUserTarget.Id);
            // Luego soft-delete del usuario
            await AuthApi.AdminDeleteUserAsync(_deleteUserTarget.Id);
            _showDeleteUserConfirm = false;
            await LoadUsers();
            await LoadStats();
            ShowToast("Usuario y sus mascotas eliminados.");
        }
        catch (Exception ex) { _deleteUserError = ex.Message; }
        finally { _deleteUserSaving = false; }
    }

