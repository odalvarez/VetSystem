@page "/notifications"
@attribute [Authorize]

@inject NotificationApiClient NotificationApi
@inject AppointmentApiClient  AppointmentApi
@inject TokenProvider         Token

<PageTitle>Notificaciones — VetSystem</PageTitle>

<div class="page-header">
    <div class="page-title">🔔 Notificaciones</div>
    <div class="page-subtitle">Envío y seguimiento de alertas</div>
</div>

<div class="page-content">

    @* Panel para enviar notificación manual (solo veterinario) *@
    <AuthorizeView Roles="Veterinarian">
        <Authorized>
            <div class="card" style="margin-bottom:28px">
                <div class="card-header">
                    <span class="card-title">Enviar notificación manual</span>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_sendError))
                    { <div class="alert alert-danger">@_sendError</div> }
                    @if (!string.IsNullOrEmpty(_sendSuccess))
                    { <div class="alert alert-success">@_sendSuccess</div> }

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Tipo</label>
                            <select class="form-control" @bind="_notifType">
                                <option value="whatsapp">WhatsApp</option>
                                <option value="email">Email</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                @(_notifType == "whatsapp" ? "Número (sin +)" : "Correo destino")
                            </label>
                            <input class="form-control" @bind="_recipient"
                                   placeholder="@(_notifType == "whatsapp" ? "573001234567" : "correo@ejemplo.com")" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mensaje</label>
                        <textarea class="form-control" rows="3" @bind="_message"
                                  placeholder="Escribe el mensaje a enviar…"></textarea>
                    </div>

                    @if (_notifType == "email")
                    {
                        <div class="form-group">
                            <label class="form-label">Asunto</label>
                            <input class="form-control" @bind="_subject" placeholder="Asunto del correo" />
                        </div>
                    }

                    <button class="btn btn-primary" @onclick="SendNotification" disabled="@_sending">
                        @if (_sending) { <span class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block"></span> }
                        else { <span>Enviar @(_notifType == "whatsapp" ? "WhatsApp" : "Email")</span> }
                    </button>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    @* Historial de notificaciones *@
    <div class="card">
        <div class="card-header">
            <span class="card-title">Historial</span>
            <button class="btn btn-ghost btn-sm" @onclick="LoadHistory">🔄 Actualizar</button>
        </div>

        @if (_loadingHistory)
        {
            <div class="card-body"><LoadingSpinner Message="Cargando historial…" /></div>
        }
        else if (_history == null || !_history.Any())
        {
            <div class="card-body">
                <div class="empty-state">
                    <div class="empty-state-icon">🔔</div>
                    <div class="empty-state-title">Sin notificaciones</div>
                    <div class="empty-state-sub">Aún no hay notificaciones enviadas.</div>
                </div>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="vet-table">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Destinatario</th>
                            <th>Estado</th>
                            <th>Enviada</th>
                            <th>Error</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var n in _history)
                        {
                            <tr>
                                <td><StatusBadge Status="@n.Type" /></td>
                                <td style="font-size:.85rem">@n.Recipient</td>
                                <td><StatusBadge Status="@n.Status" /></td>
                                <td style="font-size:.82rem;color:var(--color-text-muted)">
                                    @(n.SentAt.HasValue ? n.SentAt.Value.ToString("dd/MM/yy HH:mm") : "—")
                                </td>
                                <td style="font-size:.78rem;color:var(--color-danger)">
                                    @(n.ErrorMessage ?? "")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<NotificationStatusResponse>? _history;
    private bool   _loadingHistory = true;
    private bool   _sending;

    // Formulario manual
    private string _notifType = "whatsapp";
    private string _recipient = "";
    private string _message   = "";
    private string _subject   = "";
    private string? _sendError;
    private string? _sendSuccess;

    protected override async Task OnInitializedAsync()
        => await LoadHistory();

    private async Task LoadHistory()
    {
        _loadingHistory = true;
        try
        {
            // El endpoint de historial requiere un appointmentId; aquí usamos un endpoint
            // alternativo si existiera, pero según el contrato solo hay GetStatus por appointment.
            // Para el panel general mostramos mensaje informativo si no aplica.
            _history = [];
        }
        catch { _history = []; }
        finally { _loadingHistory = false; }
    }

    private async Task SendNotification()
    {
        _sendError = null;
        _sendSuccess = null;

        if (string.IsNullOrWhiteSpace(_recipient) || string.IsNullOrWhiteSpace(_message))
        {
            _sendError = "Completa el destinatario y el mensaje.";
            return;
        }

        _sending = true;
        try
        {
            if (_notifType == "whatsapp")
            {
                await NotificationApi.SendWhatsAppAsync(new SendWhatsAppRequest
                {
                    PhoneNumber = _recipient.Trim(),
                    Message     = _message
                });
            }
            else
            {
                await NotificationApi.SendEmailAsync(new SendEmailRequest
                {
                    ToEmail  = _recipient.Trim(),
                    Subject  = _subject,
                    Body     = _message
                });
            }
            _sendSuccess = "Notificación enviada (procesando en segundo plano).";
            _recipient = ""; _message = ""; _subject = "";
        }
        catch (Exception ex)
        {
            _sendError = $"Error al enviar: {ex.Message}";
        }
        finally
        {
            _sending = false;
        }
    }
}
