@page "/notifications"
@attribute [Authorize]
@inject NotificationApiClient NotificationApi
@inject AppointmentApiClient  AppointmentApi
@inject TokenProvider         Token
@inject NavigationManager     Nav

<PageTitle>Notificaciones — VetSystem</PageTitle>

<div class="page-header">
    <div class="page-title">🔔 Notificaciones</div>
    <div class="page-subtitle">Envío y seguimiento de alertas</div>
</div>

<div class="page-content">

    @* Panel para enviar notificación manual (veterinario y admin) *@
    <AuthorizeView Roles="Veterinarian,Admin">
        <Authorized>
            <div class="card" style="margin-bottom:28px">
                <div class="card-header">
                    <span class="card-title">Enviar notificación manual</span>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_sendError))
                    { <div class="alert alert-danger">@_sendError</div> }
                    @if (!string.IsNullOrEmpty(_sendSuccess))
                    { <div class="alert alert-success">@_sendSuccess</div> }

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Tipo</label>
                            <select class="form-control" @bind="_notifType">
                                <option value="whatsapp">WhatsApp</option>
                                <option value="email">Email</option>
                            </select>
                        </div>

                        @if (_notifType == "whatsapp")
                        {
                            <div class="form-group" style="flex:2">
                                <label class="form-label">Número WhatsApp</label>
                                <PhoneInput @bind-Value="_whatsappTo" />
                            </div>
                        }
                        else
                        {
                            <div class="form-group" style="flex:2">
                                <label class="form-label">Correo destino</label>
                                <input class="form-control" @bind="_recipient"
                                       placeholder="correo@ejemplo.com" inputmode="email" />
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mensaje</label>
                        <textarea class="form-control" rows="3" @bind="_message"
                                  placeholder="Escribe el mensaje a enviar…"></textarea>
                    </div>

                    @if (_notifType == "email")
                    {
                        <div class="form-group">
                            <label class="form-label">Asunto</label>
                            <input class="form-control" @bind="_subject" placeholder="Asunto del correo" />
                        </div>
                    }

                    <button class="btn btn-primary" @onclick="SendNotification" disabled="@_sending">
                        @if (_sending) { <span class="spinner spinner-sm"></span> }
                        else { <span>Enviar @(_notifType == "whatsapp" ? "WhatsApp" : "Email")</span> }
                    </button>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    @* Historial de notificaciones *@
    <div class="card">
        <div class="card-header">
            <span class="card-title">Historial</span>
            <button class="btn btn-ghost btn-sm" @onclick="LoadHistory">🔄 Actualizar</button>
        </div>

        @if (_loadingHistory)
        {
            <div class="card-body"><LoadingSpinner Message="Cargando historial…" /></div>
        }
        else
        {
            @* Barra de filtros *@
            <div class="card-body" style="padding-bottom:0;border-bottom:1px solid var(--color-border)">
                <div class="filters-bar">

                    @* Tipo *@
                    <select class="filter-select" @bind="_filterType">
                        <option value="">Todos los tipos</option>
                        <option value="whatsapp">WhatsApp</option>
                        <option value="email">Email</option>
                    </select>

                    @* Estado *@
                    <select class="filter-select" @bind="_filterStatus">
                        <option value="">Todos los estados</option>
                        <option value="pending">Pendiente</option>
                        <option value="sent">Enviada</option>
                        <option value="failed">Fallida</option>
                    </select>

                    @* Fecha desde — label visible porque placeholder no funciona en date inputs móviles *@
                    <label class="date-filter-label">
                        <span>Desde</span>
                        <input type="date" class="filter-select"
                               @bind="_filterFrom" />
                    </label>

                    @* Fecha hasta *@
                    <label class="date-filter-label">
                        <span>Hasta</span>
                        <input type="date" class="filter-select"
                               @bind="_filterTo" />
                    </label>

                    @* Búsqueda por destinatario — solo para admin y veterinario *@
                    <AuthorizeView Roles="Veterinarian,Admin">
                        <Authorized>
                            <div class="search-input" style="min-width:200px">
                                <span class="search-icon">🔍</span>
                                <input class="form-control"
                                       placeholder="Buscar destinatario…"
                                       @bind="_filterRecipient"
                                       @bind:event="oninput" />
                            </div>
                        </Authorized>
                    </AuthorizeView>

                    @* Limpiar filtros *@
                    @if (HasActiveFilters)
                    {
                        <button class="btn btn-ghost btn-sm" @onclick="ClearFilters"
                                style="white-space:nowrap">✕ Limpiar</button>
                    }

                    @* Contador de resultados *@
                    <span style="margin-left:auto;font-size:.82rem;color:var(--color-text-muted);align-self:center;white-space:nowrap">
                        @FilteredHistory.Count() resultado@(FilteredHistory.Count() == 1 ? "" : "s")
                        @if (HasActiveFilters && _history?.Count != FilteredHistory.Count())
                        {
                            <span> de @(_history?.Count ?? 0)</span>
                        }
                    </span>
                </div>
            </div>

            @* Tabla *@
            @if (!FilteredHistory.Any())
            {
                <div class="card-body">
                    <div class="empty-state">
                        <div class="empty-state-icon">🔔</div>
                        <div class="empty-state-title">Sin resultados</div>
                        <div class="empty-state-sub">
                            @if (HasActiveFilters)
                            { <span>Ninguna notificación coincide con los filtros aplicados.</span> }
                            else
                            { <span>Aún no hay notificaciones enviadas.</span> }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="table-wrapper">
                    <table class="vet-table">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Destinatario</th>
                                <th>Estado</th>
                                <th>Creada</th>
                                <th>Enviada</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var n in FilteredHistory)
                            {
                                <tr>
                                    <td data-label="Tipo"><StatusBadge Status="@n.Type" /></td>
                                    <td data-label="Destinatario" style="font-size:.85rem">@n.Recipient</td>
                                    <td data-label="Estado"><StatusBadge Status="@n.Status" /></td>
                                    <td data-label="Creada" style="font-size:.82rem;color:var(--color-text-muted)">
                                        @n.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")
                                    </td>
                                    <td data-label="Enviada" style="font-size:.82rem;color:var(--color-text-muted)">
                                        @(n.SentAt.HasValue ? n.SentAt.Value.ToLocalTime().ToString("dd/MM/yy HH:mm") : "—")
                                    </td>
                                    <td data-label="" class="td-actions">
                                        <span class="tip-wrap">
                                            <button class="btn btn-sm btn-icon-view"
                                                    @onclick="() => OpenDetail(n)">👁</button>
                                            <span class="tip-txt">Ver detalle</span>
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
</div>

@* Modal de detalle de notificación *@
@if (_detailNotif != null)
{
    <div class="modal-overlay" @onclick="CloseDetail">
        <div class="modal-box" style="max-width:520px;width:100%" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Detalle de notificación</span>
                <button class="btn-close" @onclick="CloseDetail">✕</button>
            </div>
            <div class="modal-body" style="display:flex;flex-direction:column;gap:14px">

                <div style="display:flex;gap:10px;align-items:center">
                    <StatusBadge Status="@_detailNotif.Type" />
                    <StatusBadge Status="@_detailNotif.Status" />
                </div>

                <div class="form-group">
                    <label class="form-label">Destinatario</label>
                    <div class="detail-value">@_detailNotif.Recipient</div>
                </div>

                @if (!string.IsNullOrEmpty(_detailNotif.Subject))
                {
                    <div class="form-group">
                        <label class="form-label">Asunto</label>
                        <div class="detail-value">@_detailNotif.Subject</div>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Mensaje</label>
                    <div class="detail-value" style="white-space:pre-wrap;background:var(--color-bg-secondary);padding:12px;border-radius:8px;font-size:.9rem;min-height:60px">@_detailNotif.Body</div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                    <div class="form-group">
                        <label class="form-label">Creada</label>
                        <div class="detail-value">@_detailNotif.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Enviada</label>
                        <div class="detail-value">
                            @(_detailNotif.SentAt.HasValue
                                ? _detailNotif.SentAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                                : "—")
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_detailNotif.Error))
                {
                    <div class="alert alert-danger" style="font-size:.85rem">@_detailNotif.Error</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseDetail">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<NotificationStatusResponse>? _history;
    private bool   _loadingHistory = true;
    private bool   _sending;

    // Modal de detalle
    private NotificationStatusResponse? _detailNotif;

    private void OpenDetail(NotificationStatusResponse n) => _detailNotif = n;
    private void CloseDetail() => _detailNotif = null;

    // Filtros del historial
    private string    _filterType      = "";
    private string    _filterStatus    = "";
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private string    _filterRecipient = "";

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(_filterType)      ||
        !string.IsNullOrEmpty(_filterStatus)    ||
        _filterFrom.HasValue                    ||
        _filterTo.HasValue                      ||
        !string.IsNullOrEmpty(_filterRecipient);

    private IEnumerable<NotificationStatusResponse> FilteredHistory
    {
        get
        {
            if (_history == null) return [];
            var q = _history.AsEnumerable();

            if (!string.IsNullOrEmpty(_filterType))
                q = q.Where(n => n.Type.Equals(_filterType, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(_filterStatus))
                q = q.Where(n => n.Status.Equals(_filterStatus, StringComparison.OrdinalIgnoreCase));

            // Compara solo la fecha (sin hora) contra CreatedAt en hora local
            if (_filterFrom.HasValue)
                q = q.Where(n => n.CreatedAt.ToLocalTime().Date >= _filterFrom.Value.Date);

            if (_filterTo.HasValue)
                q = q.Where(n => n.CreatedAt.ToLocalTime().Date <= _filterTo.Value.Date);

            if (!string.IsNullOrEmpty(_filterRecipient))
                q = q.Where(n => n.Recipient.Contains(_filterRecipient, StringComparison.OrdinalIgnoreCase));

            return q;
        }
    }

    private void ClearFilters()
    {
        _filterType      = "";
        _filterStatus    = "";
        _filterFrom      = null;
        _filterTo        = null;
        _filterRecipient = "";
    }

    // Formulario manual
    private string _notifType   = "whatsapp";
    private string _whatsappTo  = "";   // número completo emitido por PhoneInput
    private string _recipient   = "";
    private string _message     = "";
    private string _subject     = "";
    private string? _sendError;
    private string? _sendSuccess;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        _loadingHistory = true;
        try
        {
            // Si es propietario, pasa el teléfono para que el backend filtre sus notificaciones
            var user  = Token.User;
            var phone = (user?.Role?.Equals("Owner", StringComparison.OrdinalIgnoreCase) == true)
                ? user.Phone
                : null;

            _history = await NotificationApi.ListAllAsync(pageSize: 100, phone: phone);
        }
        catch { _history = []; }
        finally { _loadingHistory = false; }
    }

    private async Task SendNotification()
    {
        _sendError = null;
        _sendSuccess = null;

        if (_notifType == "whatsapp" && string.IsNullOrWhiteSpace(_whatsappTo))
        {
            _sendError = "Ingresa el número de teléfono.";
            return;
        }
        if (_notifType == "email" && string.IsNullOrWhiteSpace(_recipient))
        {
            _sendError = "Ingresa el correo destino.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_message))
        {
            _sendError = "Escribe el mensaje.";
            return;
        }

        _sending = true;
        try
        {
            if (_notifType == "whatsapp")
            {
                await NotificationApi.SendWhatsAppAsync(new SendWhatsAppRequest
                {
                    To      = _whatsappTo,
                    Message = _message
                });
            }
            else
            {
                await NotificationApi.SendEmailAsync(new SendEmailRequest
                {
                    To      = _recipient.Trim(),
                    Subject = _subject,
                    Body    = _message
                });
            }
            _sendSuccess = "Notificación enviada (procesando en segundo plano).";
            _whatsappTo = ""; _recipient = ""; _message = ""; _subject = "";
            // Espera a que el background task del backend actualice el estado en BD
            await Task.Delay(2500);
            await LoadHistory();
        }
        catch (Exception ex)
        {
            _sendError = $"Error al enviar: {ex.Message}";
        }
        finally
        {
            _sending = false;
        }
    }
}
