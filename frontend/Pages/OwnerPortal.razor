@page "/owner-portal"
@attribute [Authorize]
@inject NavigationManager Nav

@inject PatientApiClient     PatientApi
@inject AppointmentApiClient AppointmentApi
@inject TokenProvider        Token

<PageTitle>Portal del propietario — VetSystem</PageTitle>

<div class="page-header">
    <div class="page-title">🐾 Mis mascotas</div>
    <div class="page-subtitle">Portal del propietario</div>
</div>

<div class="page-content">

    @if (_loading)
    {
        <LoadingSpinner Message="Cargando…" />
    }
    else
    {
        @* ── Mascotas ── *@
        <div class="card" style="margin-bottom:28px">
            <div class="card-header">
                <span class="card-title">Mis mascotas</span>
                <button class="btn btn-primary btn-sm"
                        @onclick="() => _showNewPatient = true">
                    + Registrar mascota
                </button>
            </div>

            <div class="card-body">
                @if (_patients == null || !_patients.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🐾</div>
                        <div class="empty-state-title">No tienes mascotas registradas</div>
                        <div class="empty-state-sub">
                            Registra tu primera mascota para acceder a las funciones del portal.
                        </div>
                        <button class="btn btn-primary" style="margin-top:16px"
                                @onclick="() => _showNewPatient = true">
                            Registrar mascota
                        </button>
                    </div>
                }
                else
                {
                    <div class="patients-grid">
                        @foreach (var p in _patients)
                        {
                            <PatientCard Patient="p"
                                         OnSelect="EventCallback.Factory.Create(this, () => OpenDetail(p))" />
                        }
                    </div>
                }
            </div>
        </div>

        @* ── Citas ── *@
        <div class="card">
            <div class="card-header">
                <span class="card-title">Mis citas</span>
                <button class="btn btn-primary btn-sm"
                        @onclick="() => _showNewAppointment = true"
                        disabled="@(!(_patients?.Any() ?? false))">
                    + Solicitar cita
                </button>
            </div>

            <div class="table-wrapper">
                @if (_appointments == null || !_appointments.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">📅</div>
                        <div class="empty-state-title">No tienes citas</div>
                        @if (_patients?.Any() == true)
                        {
                            <div class="empty-state-sub">Solicita tu primera cita con el botón de arriba.</div>
                        }
                        else
                        {
                            <div class="empty-state-sub">Registra una mascota primero para poder solicitar citas.</div>
                        }
                    </div>
                }
                else
                {
                    <table class="vet-table">
                        <thead>
                            <tr>
                                <th>Mascota</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Duración</th>
                                <th>Estado</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _appointments)
                            {
                                <tr>
                                    <td data-label="Mascota"><strong>@a.PatientName</strong></td>
                                    <td data-label="Fecha">@a.ScheduledAt.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Hora">@a.ScheduledAt.ToString("HH:mm")</td>
                                    <td data-label="Duración">@a.DurationMinutes min</td>
                                    <td data-label="Estado"><StatusBadge Status="@a.Status" /></td>
                                    <td data-label="Motivo" style="color:var(--color-text-muted);font-size:.85rem">
                                        @(a.Reason ?? "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
</div>

<NewPatientModal Visible="_showNewPatient"
                 OnSaved="EventCallback.Factory.Create(this, OnPatientSaved)"
                 OnClose="EventCallback.Factory.Create(this, () => _showNewPatient = false)" />

<NewAppointmentModal Visible="_showNewAppointment"
                     OnSaved="EventCallback.Factory.Create(this, OnAppointmentSaved)"
                     OnClose="EventCallback.Factory.Create(this, () => _showNewAppointment = false)" />

@* El PatientDetailModal detecta el rol Owner internamente y deshabilita escritura *@
<PatientDetailModal Visible="_showDetail"
                    Patient="_selectedPatient"
                    OnPatientSaved="EventCallback.Factory.Create(this, OnPatientSaved)"
                    OnClose="EventCallback.Factory.Create(this, () => { _showDetail = false; _selectedPatient = null; })" />

@if (!string.IsNullOrEmpty(_toast))
{
    <div class="toast-snack">✅ @_toast</div>
}

@code {
    private List<PatientResponse>?      _patients;
    private List<AppointmentResponse>?  _appointments;
    private PatientResponse?            _selectedPatient;

    private bool    _loading            = true;
    private bool    _showNewPatient;
    private bool    _showNewAppointment;
    private bool    _showDetail;
    private string? _toast;

    protected override async Task OnInitializedAsync()
    {
        // [Authorize] garantiza autenticación; cada rol tiene su propio panel
        var role = Token.User?.Role ?? "";
        if (role.Equals("Veterinarian", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/vet-dashboard", replace: true);
            return;
        }
        if (role.Equals("Admin", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/admin", replace: true);
            return;
        }

        await Task.WhenAll(LoadPatients(), LoadAppointments());
        _loading = false;
    }

    private async Task LoadPatients()
    {
        try
        {
            var result = await PatientApi.ListAsync(page: 1, pageSize: 100);
            _patients = result?.Items ?? [];
        }
        catch { _patients = []; }
    }

    private async Task LoadAppointments()
    {
        try
        {
            _appointments = await AppointmentApi.ListAsync() ?? [];
        }
        catch { _appointments = []; }
    }

    private void OpenDetail(PatientResponse p)
    {
        _selectedPatient = p;
        _showDetail      = true;
    }

    private async Task OnPatientSaved()
    {
        await LoadPatients();
        await ShowToast("Mascota registrada correctamente.");
    }

    private async Task OnAppointmentSaved()
    {
        await LoadAppointments();
        await ShowToast("Cita solicitada correctamente.");
    }

    private async Task ShowToast(string msg)
    {
        _toast = msg;
        StateHasChanged();
        await Task.Delay(3000);
        _toast = null;
        StateHasChanged();
    }
}
