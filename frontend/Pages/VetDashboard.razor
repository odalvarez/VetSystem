@page "/vet-dashboard"
@attribute [Authorize]

@inject PatientApiClient          PatientApi
@inject AppointmentApiClient     AppointmentApi
@inject ConsultationLogApiClient LogApi
@inject AuthApiClient            AuthApi
@inject NavigationManager        Nav
@inject TokenProvider            Token

<PageTitle>Panel veterinario — VetSystem</PageTitle>

<div class="page-header">
    <div class="page-title">🩺 Panel de control</div>
    <div class="page-subtitle">Gestión de pacientes y citas</div>
</div>

<div class="page-content">

    @* ── KPIs ── *@
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label">Total pacientes</div>
            <div class="stat-value">@_totalPatients</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Citas hoy</div>
            <div class="stat-value">@_todayAppointments</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Pendientes confirmación</div>
            <div class="stat-value">@_pendingConfirmation</div>
        </div>
    </div>

    @* ── Pestañas ── *@
    <div class="admin-tabs">
        <button class="admin-tab @(_tab == "patients" ? "active" : "")" @onclick='() => SwitchTab("patients")'>
            🐾 Pacientes
        </button>
        <button class="admin-tab @(_tab == "appointments" ? "active" : "")" @onclick='() => SwitchTab("appointments")'>
            📅 Citas
        </button>
    </div>

    @* ═══════════════════════════════════════════════
       TAB: PACIENTES
       ═══════════════════════════════════════════════ *@
    @if (_tab == "patients")
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Pacientes</span>
                <div class="card-header-actions">
                    <button class="btn btn-primary btn-sm" @onclick="() => _showVetPatientModal = true">+ Registrar mascota</button>
                    <div class="filters-bar mb-0">
                        <div class="search-input" style="min-width:180px">
                            <span class="search-icon">🔍</span>
                            <input class="form-control" placeholder="Buscar por nombre…"
                                   value="@_patientSearch"
                                   @oninput="HandleSearchInput" />
                        </div>
                        <select class="filter-select" @bind="_speciesFilter" @bind:after="LoadPatients">
                            <option value="">Todas las especies</option>
                            <option value="Dog">Perros</option>
                            <option value="Cat">Gatos</option>
                            <option value="Bird">Aves</option>
                            <option value="Rabbit">Conejos</option>
                            <option value="Other">Otros</option>
                        </select>
                        <div class="owner-search-wrap">
                            @if (_selectedOwner != null)
                            {
                                <div class="owner-chip">
                                    <span>@_selectedOwner.FullName</span>
                                    <button class="owner-chip-clear" @onclick="() => SelectOwner(null)" title="Quitar filtro">✕</button>
                                </div>
                            }
                            else
                            {
                                <div style="position:relative">
                                    <input class="form-control filter-select"
                                           style="min-width:200px"
                                           placeholder="Buscar dueño…"
                                           value="@_ownerSearch"
                                           @oninput="HandleOwnerInput"
                                           @onfocus="() => _ownerSuggestOpen = true"
                                           @onblur="@(_ => Task.Delay(150).ContinueWith(_ => InvokeAsync(() => { _ownerSuggestOpen = false; StateHasChanged(); })))" />
                                    @if (_ownerSuggestOpen && !string.IsNullOrWhiteSpace(_ownerSearch))
                                    {
                                        <div class="owner-suggest-dropdown">
                                            @if (FilteredOwners.Any())
                                            {
                                                @foreach (var o in FilteredOwners.Take(8))
                                                {
                                                    var owner = o;
                                                    <div class="owner-suggest-item" @onclick="() => SelectOwner(owner)">
                                                        <div>@owner.FullName</div>
                                                        <div class="owner-suggest-sub">@owner.Email @(string.IsNullOrEmpty(owner.Phone) ? "" : $"· {owner.Phone}")</div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div style="padding:10px 12px;color:var(--color-text-muted);font-size:.85rem">Sin resultados</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body" style="padding:0">
                @if (_patientsLoading)
                {
                    <div class="loading-pad"><LoadingSpinner Message="Cargando pacientes…" /></div>
                }
                else if (_patients == null || !_patients.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🐾</div>
                        <div class="empty-state-title">No hay pacientes</div>
                        <div class="empty-state-sub">Aún no se han registrado mascotas en el sistema.</div>
                    </div>
                }
                else
                {
                    <div class="grid-pad">
                        <div class="patients-grid">
                            @foreach (var p in _patients)
                            {
                                <PatientCard Patient="p"
                                             OnSelect="EventCallback.Factory.Create(this, () => SelectPatient(p))" />
                            }
                        </div>
                        @if (_totalPatients > _pageSize)
                        {
                            <div class="pagination">
                                <button class="page-btn" disabled="@(_page == 1)" @onclick="PrevPage">‹</button>
                                <span class="page-btn active">@_page</span>
                                <button class="page-btn" disabled="@(_page * _pageSize >= _totalPatients)" @onclick="NextPage">›</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════
       TAB: CITAS
       ═══════════════════════════════════════════════ *@
    @if (_tab == "appointments")
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Citas</span>
                <div class="card-header-actions">
                    <button class="btn btn-primary btn-sm" @onclick="() => _showNewAppointmentModal = true">+ Nueva cita</button>
                    <div class="filters-bar mb-0">
                        <select class="filter-select" @bind="_statusFilter" @bind:after="LoadAppointments">
                            <option value="">Todos los estados</option>
                            <option value="Scheduled">Programadas</option>
                            <option value="Confirmed">Confirmadas</option>
                            <option value="Completed">Completadas</option>
                            <option value="Cancelled">Canceladas</option>
                            <option value="NoShow">No asistió</option>
                        </select>
                        <label class="date-filter-label">
                            <span>Desde</span>
                            <input type="date" class="filter-select" @bind="_fromFilter" @bind:after="LoadAppointments" />
                        </label>
                        <label class="date-filter-label">
                            <span>Hasta</span>
                            <input type="date" class="filter-select" @bind="_toFilter" @bind:after="LoadAppointments" />
                        </label>
                    </div>
                </div>
            </div>
            <div class="table-wrapper">
                @if (_apptsLoading)
                {
                    <div class="loading-pad"><LoadingSpinner Message="Cargando citas…" /></div>
                }
                else if (_appointments == null || !_appointments.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">📅</div>
                        <div class="empty-state-title">Sin citas</div>
                        <div class="empty-state-sub">No hay citas para los filtros seleccionados.</div>
                    </div>
                }
                else
                {
                    <table class="vet-table">
                        <thead>
                            <tr>
                                <th>Paciente / Propietario</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Duración</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _appointments)
                            {
                                <AppointmentCard Appointment="a"
                                                 ShowActions="true"
                                                 OnStatusChange="HandleStatusChange"
                                                 OnOpenLog="EventCallback.Factory.Create<AppointmentResponse>(this, OpenAppointmentLog)" />
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

</div>

@* Modal para registrar nueva mascota *@
<VetNewPatientModal Visible="_showVetPatientModal"
                    OnSaved="EventCallback.Factory.Create(this, OnPatientCreated)"
                    OnClose="EventCallback.Factory.Create(this, () => _showVetPatientModal = false)" />

@* Modal de detalle: datos, bitácoras e historia clínica *@
<PatientDetailModal Visible="_showRecordModal"
                    Patient="_selectedPatient"
                    InitialReferenceLog="_referenceLog"
                    OnPatientSaved="EventCallback.Factory.Create(this, OnPatientUpdated)"
                    OnPatientDeleted="EventCallback.Factory.Create(this, OnPatientDeletedFromModal)"
                    OnClose="EventCallback.Factory.Create(this, () => { _showRecordModal = false; _selectedPatient = null; _referenceLog = null; })" />

@* Modal para crear nueva cita *@
<NewAppointmentModal Visible="_showNewAppointmentModal"
                     OnSaved="EventCallback.Factory.Create(this, async () => { await LoadAppointments(); await RefreshKpis(); })"
                     OnClose="EventCallback.Factory.Create(this, () => _showNewAppointmentModal = false)" />

@* Modal de bitácora vinculada a una cita *@
<AppointmentLogModal Visible="_showLogModal"
                     Appointment="_logAppointment"
                     OnClose="EventCallback.Factory.Create(this, () => { _showLogModal = false; _logAppointment = null; })"
                     OnGoToHC="EventCallback.Factory.Create<ConsultationLogResponse>(this, OpenHCFromLog)" />

@if (!string.IsNullOrEmpty(_toast))
{
    <div class="toast-snack @(_toastIsError ? "toast-error" : "")">
        @(_toastIsError ? "❌" : "✅") @_toast
    </div>
}

@code {
    private string _tab = "patients";

    private List<PatientResponse>?     _patients;
    private List<AppointmentResponse>? _appointments;
    private List<OwnerSummary>         _owners = [];

    private bool _patientsLoading = true;
    private bool _apptsLoading    = false;

    private int  _page     = 1;
    private int  _pageSize = 12;
    private int  _totalPatients;
    private int  _todayAppointments;
    private int  _pendingConfirmation;

    private string        _patientSearch    = "";
    private string        _speciesFilter    = "";
    private string        _statusFilter     = "";
    private DateTime?     _fromFilter;
    private DateTime?     _toFilter;
    private OwnerSummary? _selectedOwner;
    private string        _ownerSearch      = "";
    private bool          _ownerSuggestOpen;

    private bool            _showVetPatientModal     = false;
    private bool            _showRecordModal         = false;
    private bool            _showNewAppointmentModal = false;
    private bool            _showLogModal            = false;
    private PatientResponse?     _selectedPatient    = null;
    private AppointmentResponse? _logAppointment     = null;
    private ConsultationLogResponse? _referenceLog   = null;
    private string? _toast;
    private bool    _toastIsError;

    private IEnumerable<OwnerSummary> FilteredOwners =>
        _owners.Where(o =>
            o.FullName.Contains(_ownerSearch, StringComparison.OrdinalIgnoreCase) ||
            o.Email.Contains(_ownerSearch, StringComparison.OrdinalIgnoreCase)    ||
            (o.Phone ?? "").Contains(_ownerSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var role = Token.User?.Role ?? "";
        // Admin también tiene acceso completo al panel de veterinario
        var isVetOrAdmin = role.Equals("Veterinarian", StringComparison.OrdinalIgnoreCase)
                        || role.Equals("Admin",        StringComparison.OrdinalIgnoreCase);
        if (!isVetOrAdmin)
        {
            Nav.NavigateTo("/owner-portal", replace: true);
            return;
        }

        var uri  = new Uri(Nav.Uri);
        var qs   = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tab  = qs["tab"] ?? "patients";
        _tab     = tab is "patients" or "appointments" ? tab : "patients";

        var tasks = new List<Task> { LoadPatients(), LoadOwners() };
        if (_tab == "appointments") tasks.Add(LoadAppointments());
        await Task.WhenAll(tasks);

        _patientsLoading = false;
    }

    private async Task SwitchTab(string tab)
    {
        if (_tab == tab) return;
        _tab = tab;
        Nav.NavigateTo($"/vet-dashboard?tab={tab}", replace: true);
        if (tab == "appointments" && _appointments == null)
        {
            _apptsLoading = true;
            await LoadAppointments();
            _apptsLoading = false;
        }
    }

    private async Task RefreshKpis()
    {
        // Recalcula KPIs desde los datos ya cargados
        if (_appointments != null)
        {
            _todayAppointments  = _appointments.Count(a => a.ScheduledAt.Date == DateTime.Today);
            _pendingConfirmation = _appointments.Count(a => a.Status == "Scheduled");
        }
        await Task.CompletedTask;
    }

    private async Task LoadOwners()
    {
        try { _owners = await AuthApi.GetOwnersAsync(); }
        catch { _owners = []; }
    }

    private async Task LoadPatients()
    {
        _patientsLoading = true;
        try
        {
            var result = await PatientApi.ListAsync(
                page: _page, pageSize: _pageSize,
                species: string.IsNullOrEmpty(_speciesFilter) ? null : _speciesFilter,
                search: string.IsNullOrEmpty(_patientSearch) ? null : _patientSearch,
                ownerId: _selectedOwner?.Id);

            _patients      = result?.Items ?? [];
            _totalPatients = result?.TotalCount ?? 0;
        }
        catch { _patients = []; }
        finally { _patientsLoading = false; }
    }

    private async Task OnPatientCreated()
    {
        await LoadPatients();
        await RefreshKpis();
        ShowToast("Mascota registrada correctamente.");
    }

    private async Task OnPatientUpdated()
    {
        await LoadPatients();
        ShowToast("Mascota actualizada correctamente.");
    }

    private async Task OnPatientDeletedFromModal()
    {
        _showRecordModal  = false;
        _selectedPatient  = null;
        await LoadPatients();
        ShowToast("Mascota eliminada correctamente.");
    }

    private async Task LoadAppointments()
    {
        _apptsLoading = true;
        try
        {
            var result = await AppointmentApi.ListAsync(
                status: string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter,
                from: _fromFilter,
                to: _toFilter);

            _appointments        = result ?? [];
            _todayAppointments   = _appointments.Count(a => a.ScheduledAt.Date == DateTime.Today);
            _pendingConfirmation = _appointments.Count(a => a.Status == "Scheduled");
        }
        catch { _appointments = []; }
        finally { _apptsLoading = false; }
    }

    private void HandleOwnerInput(ChangeEventArgs e)
    {
        _ownerSearch      = e.Value?.ToString() ?? "";
        _ownerSuggestOpen = true;
    }

    private async Task SelectOwner(OwnerSummary? owner)
    {
        _selectedOwner    = owner;
        _ownerSearch      = "";
        _ownerSuggestOpen = false;
        _page = 1;
        await LoadPatients();
    }

    private void SelectPatient(PatientResponse p)
    {
        _selectedPatient = p;
        _showRecordModal = true;
    }

    private async Task HandleStatusChange((Guid Id, string Status) args)
    {
        if (args.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
        {
            var appt = _appointments?.FirstOrDefault(a => a.Id == args.Id);
            if (appt != null)
            {
                var log = await LogApi.GetByAppointmentAsync(appt.PatientId, appt.Id);
                if (log == null || log.IsOpen)
                {
                    ShowToast("Debes cerrar la bitácora de la cita antes de completarla.", isError: true);
                    return;
                }
            }
        }

        try
        {
            await AppointmentApi.ChangeStatusAsync(args.Id, args.Status);
            await LoadAppointments();
            ShowToast("Estado actualizado correctamente.");
        }
        catch (Exception ex)
        {
            ShowToast($"Error: {ex.Message}", isError: true);
        }
    }

    private void HandleSearchInput(ChangeEventArgs e)
    {
        _patientSearch = e.Value?.ToString() ?? "";
        _ = OnPatientSearchChanged();
    }

    private System.Threading.CancellationTokenSource? _searchCts;
    private async Task OnPatientSearchChanged()
    {
        _searchCts?.Cancel();
        _searchCts = new();
        try
        {
            await Task.Delay(400, _searchCts.Token);
            _page = 1;
            await LoadPatients();
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task PrevPage() { _page--; await LoadPatients(); }
    private async Task NextPage() { _page++; await LoadPatients(); }

    private void OpenAppointmentLog(AppointmentResponse appt)
    {
        _logAppointment = appt;
        _showLogModal   = true;
    }

    // Abre la historia clínica del paciente con la bitácora como referencia
    private async Task OpenHCFromLog(ConsultationLogResponse log)
    {
        _showLogModal  = false;
        _logAppointment = null;
        _referenceLog  = log;

        var patient = _patients?.FirstOrDefault(p => p.Id == log.PatientId)
                   ?? await PatientApi.GetAsync(log.PatientId);

        if (patient != null)
        {
            _selectedPatient = patient;
            _showRecordModal = true;
        }
    }

    private async void ShowToast(string msg, bool isError = false)
    {
        _toast        = msg;
        _toastIsError = isError;
        StateHasChanged();
        await Task.Delay(3000);
        _toast = null;
        StateHasChanged();
    }
}
