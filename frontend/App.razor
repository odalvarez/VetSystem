@inject NavigationManager Nav
@inject TokenProvider     Token
@inject AuthApiClient     AuthApi

@if (!_ready)
{
    return;
}

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @{ Nav.NavigateTo("/login", replace: true); }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Página no encontrada — VetSystem</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="not-found-container">
                    <h2>404 — Página no encontrada</h2>
                    <a href="/">Volver al inicio</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        // Verifica si la cookie httpOnly sigue siendo válida.
        // Si el servidor responde con el perfil, la sesión se restaura sin que el cliente
        // haya tenido acceso al token en ningún momento.
        var profile = await AuthApi.GetProfileAsync();
        if (profile is not null)
        {
            Token.SetSession(new VetSystem.Frontend.Models.LoginUserInfo
            {
                Id       = profile.Id,
                Email    = profile.Email,
                FullName = $"{profile.FirstName} {profile.LastName}".Trim(),
                Role     = profile.Role,
                Phone    = profile.Phone
            });
        }

        _ready = true;
    }
}
