@* Campo etiqueta/valor compacto para la exploración física *@
<div>
    <div style="font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--color-text-muted)">@Label</div>
    <div style="font-size:.88rem;font-weight:600">@Value</div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
}
