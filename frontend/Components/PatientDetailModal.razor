@* Modal de detalle de paciente con 3 pestañas:
   Datos (editar ficha) | Bitácoras (consultation logs) | Historia clínica (clinical records)
   Abierto tanto por el veterinario como por el propietario (lectura diferenciada por rol). *@
@inject PatientApiClient          PatientApi
@inject ConsultationLogApiClient  LogApi
@inject VaccinationApiClient      VaccApi
@inject TokenProvider             Token

@if (Visible && Patient != null)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-box" style="max-width:860px;width:100%;max-height:92vh;display:flex;flex-direction:column"
             @onclick:stopPropagation>

            @* ── Cabecera ── *@
            <div class="modal-header" style="flex-shrink:0">
                <div>
                    <div class="modal-title">🐾 @Patient.Name</div>
                    <div style="font-size:.8rem;color:var(--color-text-muted);margin-top:2px">
                        @Patient.SpeciesName · @Patient.Breed · @Patient.OwnerName
                    </div>
                </div>
                <button class="btn-close" @onclick="Close">✕</button>
            </div>

            @* ── Tabs ── *@
            <div style="display:flex;justify-content:center;border-bottom:2px solid var(--color-border);flex-shrink:0;padding:0 26px">
                <button class="admin-tab @(_tab == "data"    ? "active" : "")" @onclick='() => SwitchTab("data")'>
                    📋 Datos
                </button>
                <button class="admin-tab @(_tab == "logs"    ? "active" : "")" @onclick='() => SwitchTab("logs")'>
                    📝 Bitácoras @if (_logCount > 0) { <span class="tab-count">@_logCount</span> }
                </button>
                <button class="admin-tab @(_tab == "records" ? "active" : "")" @onclick='() => SwitchTab("records")'>
                    🏥 Historia clínica @if (_recordCount > 0) { <span class="tab-count">@_recordCount</span> }
                </button>
                <button class="admin-tab @(_tab == "vaccines" ? "active" : "")" @onclick='() => SwitchTab("vaccines")'>
                    💉 Vacunas @if (_vaccineCount > 0) { <span class="tab-count">@_vaccineCount</span> }
                </button>
            </div>

            @* ── Contenido del tab (scrollable) ── *@
            <div style="overflow-y:auto;flex:1;padding:24px 26px">

                @* ════════════════════════════════
                   TAB: DATOS
                   ════════════════════════════════ *@
                @if (_tab == "data")
                {
                    @if (!string.IsNullOrEmpty(_dataError))
                    { <div class="alert alert-danger">@_dataError</div> }

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nombre *</label>
                            <input class="form-control" @bind="_edit.Name" disabled="@IsOwner" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Raza *</label>
                            <input class="form-control" @bind="_edit.Breed" disabled="@IsOwner" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Especie</label>
                            <input class="form-control" value="@Patient.SpeciesName" disabled />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Sexo</label>
                            <select class="form-control" @bind="_edit.Sex" disabled="@IsOwner">
                                <option value="male">Macho</option>
                                <option value="female">Hembra</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Fecha de nac. aproximada</label>
                            <input type="date" class="form-control"
                                   value="@_edit.BirthDate.ToString("yyyy-MM-dd")"
                                   max="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")"
                                   @oninput="HandleBirthDate"
                                   disabled="@IsOwner" />
                            <div class="form-hint">Edad: <strong>@AgeLabel(_edit.BirthDate)</strong></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Peso (kg) *</label>
                            <input type="number" step="0.01" min="0.01" class="form-control"
                                   @bind="_edit.WeightKg" disabled="@IsOwner" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Color</label>
                            <input class="form-control" @bind="_edit.Color" disabled="@IsOwner" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Microchip</label>
                            <input class="form-control" @bind="_edit.MicrochipNumber" disabled="@IsOwner" />
                        </div>
                    </div>

                    @if (!IsOwner)
                    {
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px">
                            @if (IsAdmin)
                            {
                                @if (_confirmingDelete)
                                {
                                    <div style="display:flex;align-items:center;gap:8px">
                                        <span style="font-size:.875rem;color:var(--color-danger)">¿Eliminar mascota?</span>
                                        <button class="btn btn-danger btn-sm" @onclick="DeletePatient" disabled="@_deleting">
                                            @if (_deleting) { <span class="spinner spinner-sm"></span> }
                                            else { <span>Confirmar</span> }
                                        </button>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => _confirmingDelete = false">Cancelar</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-danger btn-sm" @onclick="() => _confirmingDelete = true">
                                        🗑️ Eliminar mascota
                                    </button>
                                }
                            }
                            else
                            {
                                <div></div>
                            }
                            <button class="btn btn-primary" @onclick="SaveData" disabled="@_saving">
                                @if (_saving) { <span class="spinner spinner-sm"></span> }
                                else { <span>Guardar cambios</span> }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_deleteError))
                        { <div class="alert alert-danger" style="margin-top:8px">⚠️ @_deleteError</div> }
                    }
                }

                @* ════════════════════════════════
                   TAB: BITÁCORAS
                   ════════════════════════════════ *@
                @if (_tab == "logs")
                {
                    @if (_logsLoading)
                    {
                        <LoadingSpinner Message="Cargando bitácoras…" />
                    }
                    else if (_showLogForm)
                    {
                        @* ── Formulario de creación / edición ── *@
                        <ConsultationLogForm
                            Log="_editingLog"
                            PatientId="Patient.Id"
                            OnSaved="OnLogSaved"
                            OnCancel="CancelLogForm" />
                    }
                    else if (_closedLog != null)
                    {
                        @* ── Vista post-cierre: resumen de la bitácora cerrada ── *@
                        <div class="alert alert-success" style="margin-bottom:16px">
                            ✅ Bitácora cerrada correctamente.
                        </div>
                        <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
                            <button class="btn btn-primary"
                                    @onclick="GoToRecordsWithReference">
                                📋 Ir a historia clínica →
                            </button>
                        </div>
                        <ConsultationLogReadOnly Log="_closedLog" />
                        <div style="margin-top:16px;display:flex;gap:10px;justify-content:flex-end">
                            <button class="btn btn-ghost" @onclick="() => _closedLog = null">
                                ← Ver lista de bitácoras
                            </button>
                        </div>
                    }
                    else
                    {
                        @if (!IsOwner)
                        {
                            <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
                                <button class="btn btn-primary btn-sm" @onclick="OpenNewLogForm">
                                    + Nueva bitácora
                                </button>
                            </div>
                        }

                        @if (!_logs.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-state-icon">📝</div>
                                <div class="empty-state-title">Sin bitácoras</div>
                                <div class="empty-state-sub">
                                    @(IsOwner ? "Este paciente no tiene bitácoras de consulta aún."
                                               : "Crea la primera bitácora para registrar una consulta.")
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var log in _logs)
                            {
                                <div class="log-list-item @(log.IsOpen ? "log-open" : "log-closed")"
                                     style="cursor:pointer" @onclick="() => SelectLog(log)">
                                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                                        <span class="badge @(log.IsOpen ? "badge-scheduled" : "badge-completed")">
                                            @(log.IsOpen ? "Abierta" : "Cerrada")
                                        </span>
                                        <span style="font-weight:600;font-size:.92rem">@log.ReasonForVisit</span>
                                        <span style="margin-left:auto;font-size:.78rem;color:var(--color-text-muted)">
                                            @log.OpenedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                            · @log.VeterinarianName
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    }

                    @* ── Detalle de bitácora seleccionada ── *@
                    @if (_selectedLog != null && !_showLogForm && _closedLog == null)
                    {
                        <div class="modal-overlay" @onclick="() => _selectedLog = null">
                            <div class="modal-box" style="max-width:760px;width:100%;max-height:90vh;overflow-y:auto"
                                 @onclick:stopPropagation>
                                <div class="modal-header">
                                    <span class="modal-title">
                                        Bitácora — @_selectedLog.OpenedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                    </span>
                                    <div style="display:flex;gap:8px;align-items:center">
                                        @if (_selectedLog.IsOpen && !IsOwner)
                                        {
                                            <button class="btn btn-sm btn-secondary"
                                                    @onclick="() => OpenEditLogForm(_selectedLog)">
                                                ✏️ Editar
                                            </button>
                                            <button class="btn btn-sm btn-danger"
                                                    @onclick="() => _ = CloseLogAsync(_selectedLog)"
                                                    disabled="@_closingLog">
                                                @if (_closingLog) { <span class="spinner spinner-sm"></span> }
                                                else { <span>🔒 Cerrar bitácora</span> }
                                            </button>
                                        }
                                        <button class="btn-close" @onclick="() => _selectedLog = null">✕</button>
                                    </div>
                                </div>
                                <div class="modal-body">
                                    @if (!string.IsNullOrEmpty(_logError))
                                    { <div class="alert alert-danger">@_logError</div> }
                                    <ConsultationLogReadOnly Log="_selectedLog" />
                                </div>
                            </div>
                        </div>
                    }
                }

                @* ════════════════════════════════
                   TAB: HISTORIA CLÍNICA
                   ════════════════════════════════ *@
                @if (_tab == "records")
                {
                    @* Panel flotante de referencia (bitácora recién cerrada) *@
                    @if (_referenceLog != null)
                    {
                        <div class="reference-log-panel">
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                                <div style="font-weight:700;font-size:.92rem;color:var(--color-primary)">
                                    📋 Bitácora de referencia — @_referenceLog.OpenedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                </div>
                                <div style="display:flex;gap:8px;align-items:center">
                                    <button class="btn btn-ghost btn-sm"
                                            @onclick="() => _refCollapsed = !_refCollapsed">
                                        @(_refCollapsed ? "▼ Expandir" : "▲ Colapsar")
                                    </button>
                                    <button class="btn-close" style="font-size:1rem"
                                            @onclick="() => _referenceLog = null">✕</button>
                                </div>
                            </div>
                            @if (!_refCollapsed)
                            {
                                <ConsultationLogReadOnly Log="_referenceLog" Compact="true" />
                            }
                        </div>
                    }

                    @if (!IsOwner && !_showRecordForm)
                    {
                        <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
                            <button class="btn btn-primary btn-sm" @onclick="() => _showRecordForm = true">
                                + Agregar entrada
                            </button>
                        </div>
                    }

                    @if (_showRecordForm)
                    {
                        <div class="card" style="margin-bottom:20px">
                            <div class="card-header">
                                <span class="card-title">Nueva entrada en historia clínica</span>
                                <button class="btn-close" @onclick="() => _showRecordForm = false">✕</button>
                            </div>
                            <div class="card-body">
                                @if (!string.IsNullOrEmpty(_recordError))
                                { <div class="alert alert-danger">@_recordError</div> }

                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Fecha *</label>
                                        <input type="date" class="form-control"
                                               value="@_recDateStr"
                                               max="@DateTime.Today.ToString("yyyy-MM-dd")"
                                               @oninput="e => _recDateStr = e.Value?.ToString() ?? string.Empty" />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Próxima visita</label>
                                        <input type="date" class="form-control"
                                               value="@_recNextStr"
                                               @oninput="e => _recNextStr = e.Value?.ToString() ?? string.Empty" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Motivo *</label>
                                    <input class="form-control" @bind="_rec.Reason"
                                           placeholder="Motivo de la consulta" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Diagnóstico *</label>
                                    <input class="form-control" @bind="_rec.Diagnosis"
                                           placeholder="Diagnóstico" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Tratamiento *</label>
                                    <textarea class="form-control" rows="3" @bind="_rec.Treatment"
                                              placeholder="Tratamiento indicado…"></textarea>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Notas</label>
                                    <textarea class="form-control" rows="2" @bind="_rec.Notes"
                                              placeholder="Observaciones adicionales…"></textarea>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Peso (kg)</label>
                                        <input type="number" step="0.1" min="0" class="form-control"
                                               @bind="_rec.WeightKg" />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Temperatura (°C)</label>
                                        <input type="number" step="0.1" min="35" max="42" class="form-control"
                                               @bind="_rec.TemperatureCelsius" />
                                    </div>
                                </div>
                                <div style="display:flex;gap:10px;justify-content:flex-end">
                                    <button class="btn btn-ghost" @onclick="() => _showRecordForm = false">Cancelar</button>
                                    <button class="btn btn-primary" @onclick="SaveRecord" disabled="@_savingRecord">
                                        @if (_savingRecord) { <span class="spinner spinner-sm"></span> }
                                        else { <span>Guardar entrada</span> }
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_recordsLoading)
                    {
                        <LoadingSpinner Message="Cargando historia clínica…" />
                    }
                    else if (!_records.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">🏥</div>
                            <div class="empty-state-title">Sin entradas</div>
                            <div class="empty-state-sub">La historia clínica de @Patient.Name está vacía.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var r in _records)
                        {
                            <div class="record-entry">
                                <div class="record-entry-header">
                                    <div>
                                        <span style="font-weight:700">@r.Date.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                        <span style="margin-left:10px;font-size:.85rem;color:var(--color-text-muted)">
                                            Dr. @r.VeterinarianName
                                        </span>
                                    </div>
                                    @if (r.NextVisitDate.HasValue)
                                    {
                                        <span style="font-size:.78rem;color:var(--color-primary)">
                                            Próxima visita: @r.NextVisitDate.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                </div>
                                <div class="record-entry-body">
                                    <RecordField Label="Motivo"      Value="@r.Reason" />
                                    <RecordField Label="Diagnóstico" Value="@r.Diagnosis" />
                                    <RecordField Label="Tratamiento" Value="@r.Treatment" />
                                    @if (!string.IsNullOrEmpty(r.Notes))
                                    { <RecordField Label="Notas" Value="@r.Notes" /> }
                                    @if (r.WeightKg.HasValue || r.TemperatureCelsius.HasValue)
                                    {
                                        <div style="display:flex;gap:20px;margin-top:6px">
                                            @if (r.WeightKg.HasValue)
                                            { <span style="font-size:.82rem"><strong>Peso:</strong> @r.WeightKg kg</span> }
                                            @if (r.TemperatureCelsius.HasValue)
                                            { <span style="font-size:.82rem"><strong>Temp:</strong> @r.TemperatureCelsius °C</span> }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                }

                @* ════════════════════════════════
                   TAB: VACUNAS
                   ════════════════════════════════ *@
                @if (_tab == "vaccines")
                {
                    @if (!IsOwner)
                    {
                        <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
                            <button class="btn btn-primary btn-sm" @onclick="() => _showVaccineForm = !_showVaccineForm">
                                @(_showVaccineForm ? "Cancelar" : "+ Registrar dosis")
                            </button>
                        </div>

                        @if (_showVaccineForm)
                        {
                            <div class="form-card" style="margin-bottom:20px">
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Vacuna</label>
                                        <select class="form-control" @bind="_vaccReq.VaccineDefinitionId">
                                            <option value="@Guid.Empty">— Selecciona —</option>
                                            @foreach (var v in _vaccineDefinitions.Where(d => d.IsActive))
                                            {
                                                <option value="@v.Id">@v.Name (@v.Scheme)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>Fecha de aplicación</label>
                                        <input class="form-control" type="date"
                                               value="@_vaccReq.AdministeredAt"
                                               @onchange="e => _vaccReq.AdministeredAt = e.Value?.ToString() ?? string.Empty" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Lote (opcional)</label>
                                        <input class="form-control" type="text" placeholder="Número de lote"
                                               value="@_vaccReq.BatchNumber"
                                               @onchange="e => _vaccReq.BatchNumber = e.Value?.ToString()" />
                                    </div>
                                    <div class="form-group">
                                        <label>Próximo refuerzo (opcional — sobreescribe cálculo)</label>
                                        <input class="form-control" type="date"
                                               value="@_vaccReq.NextDueDateOverride"
                                               @onchange="e => _vaccReq.NextDueDateOverride = e.Value?.ToString()" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Notas</label>
                                    <textarea class="form-control" rows="2"
                                              @onchange="e => _vaccReq.Notes = e.Value?.ToString()">@_vaccReq.Notes</textarea>
                                </div>
                                @if (!string.IsNullOrEmpty(_vaccError))
                                {
                                    <p style="color:var(--color-danger);margin:6px 0">@_vaccError</p>
                                }
                                <div style="display:flex;justify-content:flex-end;margin-top:10px">
                                    <button class="btn btn-primary" @onclick="SaveVaccinationAsync"
                                            disabled="@_vaccSaving">
                                        @(_vaccSaving ? "Guardando..." : "Guardar")
                                    </button>
                                </div>
                            </div>
                        }
                    }

                    @if (!_vaccRecords.Any())
                    {
                        <p class="empty-state-text">No hay vacunas registradas para esta mascota.</p>
                    }
                    else
                    {
                        @foreach (var r in _vaccRecords)
                        {
                            <div class="record-entry" style="margin-bottom:10px">
                                <div class="record-entry-header">
                                    <div>
                                        <span style="font-weight:600">@r.VaccineName</span>
                                        <span style="margin-left:8px;font-size:.8rem;color:var(--color-text-muted)">Dosis @r.DoseNumber</span>
                                        @{
                                            var (badgeColor, badgeLabel) = r.DueStatus switch
                                            {
                                                "overdue"  => ("var(--color-danger)", "Vencida"),
                                                "upcoming" => ("var(--color-warning, #F59E0B)", "Próxima"),
                                                "ok"       => ("var(--color-success, #10B981)", "Al día"),
                                                _          => ("var(--color-text-muted)", "Dosis única"),
                                            };
                                        }
                                        <span style="margin-left:8px;font-size:.75rem;font-weight:600;color:@badgeColor">
                                            @badgeLabel
                                        </span>
                                    </div>
                                    <div style="font-size:.82rem;color:var(--color-text-muted)">
                                        @r.AdministeredAt
                                        @if (!string.IsNullOrEmpty(r.NextDueDate))
                                        { <span style="margin-left:8px">· Próximo: <strong>@r.NextDueDate</strong></span> }
                                    </div>
                                </div>
                                <div class="record-entry-body">
                                    <RecordField Label="Aplicado por" Value="@r.AdministeredByName" />
                                    @if (!string.IsNullOrEmpty(r.BatchNumber))
                                    { <RecordField Label="Lote" Value="@r.BatchNumber" /> }
                                    @if (!string.IsNullOrEmpty(r.Notes))
                                    { <RecordField Label="Notas" Value="@r.Notes" /> }
                                </div>
                                @if (IsAdmin)
                                {
                                    <div style="display:flex;justify-content:flex-end;padding:4px 12px 8px">
                                        <button class="btn btn-ghost btn-sm"
                                                style="color:var(--color-danger)"
                                                @onclick="() => DeleteVaccinationAsync(r.Id)">
                                            Eliminar
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    }
                }

            </div>@* fin scroll area *@
        </div>
    </div>
}

@code {
    [Parameter] public bool            Visible          { get; set; }
    [Parameter] public PatientResponse? Patient          { get; set; }
    [Parameter] public EventCallback   OnClose          { get; set; }
    [Parameter] public EventCallback   OnPatientSaved   { get; set; }
    [Parameter] public EventCallback   OnPatientDeleted { get; set; }
    // Bitácora de referencia inyectada desde el flow cita → HC
    [Parameter] public ConsultationLogResponse? InitialReferenceLog { get; set; }

    // ── Roles ──────────────────────────────────────────────────
    private bool IsOwner => Token.User?.Role?.Equals("Owner", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsAdmin => Token.User?.Role?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;

    // ── Tab activa ──────────────────────────────────────────────
    private string _tab = "data";

    // ── Tab datos ──────────────────────────────────────────────
    private UpdatePatientRequest _edit        = new();
    private bool    _saving      = false;
    private string? _dataError;
    private bool    _deleting         = false;
    private bool    _confirmingDelete = false;
    private string? _deleteError;

    // ── Tab bitácoras ───────────────────────────────────────────
    private List<ConsultationLogResponse>  _logs         = [];
    private bool                           _logsLoading  = false;
    private bool                           _showLogForm  = false;
    private ConsultationLogResponse?       _editingLog;   // null = crear, non-null = editar
    private ConsultationLogResponse?       _selectedLog;  // detalle abierto
    private ConsultationLogResponse?       _closedLog;    // vista post-cierre
    private bool                           _closingLog   = false;
    private string?                        _logError;
    private int                            _logCount;

    // ── Tab historia clínica ────────────────────────────────────
    private List<ClinicalRecordResponse>   _records        = [];
    private bool                           _recordsLoading = false;
    private bool                           _showRecordForm = false;
    private bool                           _savingRecord   = false;
    private string?                        _recordError;
    private int                            _recordCount;
    private CreateClinicalRecordRequest    _rec            = new();
    private string                         _recDateStr     = DateTime.Today.ToString("yyyy-MM-dd");
    private string                         _recNextStr     = "";
    // Panel de referencia (bitácora recién cerrada pasada al tab de HC)
    private ConsultationLogResponse?       _referenceLog;
    private bool                           _refCollapsed   = false;

    // ── Tab vacunas ─────────────────────────────────────────────
    private List<VaccinationRecordResponse>  _vaccRecords        = [];
    private List<VaccineDefinitionResponse>  _vaccineDefinitions = [];
    private bool                             _showVaccineForm    = false;
    private bool                             _vaccSaving         = false;
    private string?                          _vaccError;
    private int                              _vaccineCount;
    private RegisterVaccinationRequest       _vaccReq            = new()
        { AdministeredAt = DateTime.Today.ToString("yyyy-MM-dd") };

    private bool _prevVisible;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && Patient != null && !_prevVisible)
        {
            // Reinicia el estado al abrir con un paciente nuevo
            _tab          = InitialReferenceLog != null ? "records" : "data";
            _closedLog    = null;
            _referenceLog = InitialReferenceLog;
            _refCollapsed = false;
            _selectedLog  = null;
            _showLogForm  = false;
            _showRecordForm   = false;
            _showVaccineForm  = false;
            _vaccError        = null;
            _dataError        = null;
            _logError         = null;
            _recordError      = null;
            _confirmingDelete = false;
            _deleteError      = null;
            _vaccReq          = new() { AdministeredAt = DateTime.Today.ToString("yyyy-MM-dd") };

            LoadEditForm();
            await LoadLogsAsync();
            await LoadRecordsAsync();
            await LoadVaccinationsAsync();
        }
        _prevVisible = Visible;
    }

    private void LoadEditForm()
    {
        if (Patient == null) return;
        _edit = new UpdatePatientRequest
        {
            Name            = Patient.Name,
            Breed           = Patient.Breed,
            BirthDate       = Patient.BirthDate,
            Sex             = Patient.Sex,
            WeightKg        = Patient.WeightKg,
            Color           = Patient.Color,
            MicrochipNumber = Patient.MicrochipNumber
        };
    }

    private void SwitchTab(string tab)
    {
        _tab = tab;
        // Limpia el panel de referencia si el usuario sale del tab de HC manualmente
        // (el panel solo desaparece al navegar FUERA del modal o al cerrarlo manualmente)
    }

    // ── Datos ───────────────────────────────────────────────────

    private async Task SaveData()
    {
        _dataError = null;
        if (string.IsNullOrWhiteSpace(_edit.Name) || string.IsNullOrWhiteSpace(_edit.Breed))
        { _dataError = "Nombre y raza son obligatorios."; return; }
        if (_edit.WeightKg <= 0)
        { _dataError = "El peso debe ser mayor que cero."; return; }

        _saving = true;
        try
        {
            await PatientApi.UpdateAsync(Patient!.Id, _edit);
            await OnPatientSaved.InvokeAsync();
        }
        catch (Exception ex) { _dataError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task DeletePatient()
    {
        _deleteError = null;
        _deleting    = true;
        try
        {
            await PatientApi.DeleteAsync(Patient!.Id);
            _confirmingDelete = false;
            await OnPatientDeleted.InvokeAsync();
        }
        catch (Exception ex) { _deleteError = ex.Message; }
        finally { _deleting = false; }
    }

    private void HandleBirthDate(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            _edit.BirthDate = d;
    }

    // ── Bitácoras ───────────────────────────────────────────────

    private async Task LoadLogsAsync()
    {
        _logsLoading = true;
        try
        {
            var result = await LogApi.ListAsync(Patient!.Id, pageSize: 50);
            _logs      = result.Items.ToList();
            _logCount  = result.TotalCount;
        }
        catch { _logs = []; }
        finally { _logsLoading = false; }
    }


    private void OpenNewLogForm()
    {
        _editingLog  = null;
        _showLogForm = true;
    }

    private void OpenEditLogForm(ConsultationLogResponse log)
    {
        _editingLog  = log;
        _selectedLog = null;
        _showLogForm = true;
    }

    private async Task OnLogSaved()
    {
        _showLogForm = false;
        _editingLog  = null;
        await LoadLogsAsync();
    }

    private void CancelLogForm()
    {
        _showLogForm = false;
        _editingLog  = null;
    }

    private void SelectLog(ConsultationLogResponse log) => _selectedLog = log;

    private async Task CloseLogAsync(ConsultationLogResponse log)
    {
        _closingLog = true;
        _logError   = null;
        try
        {
            var closed   = await LogApi.CloseAsync(Patient!.Id, log.Id);
            _closedLog   = closed;
            _selectedLog = null;
            await LoadLogsAsync();
        }
        catch (Exception ex) { _logError = ex.Message; }
        finally { _closingLog = false; }
    }

    // Lleva al tab de Historia Clínica con el panel de referencia activo
    private void GoToRecordsWithReference()
    {
        _referenceLog = _closedLog;
        _refCollapsed = false;
        _closedLog    = null;
        _tab          = "records";
    }

    // ── Historia clínica ────────────────────────────────────────

    private async Task LoadRecordsAsync()
    {
        _recordsLoading = true;
        try
        {
            var result  = await PatientApi.ListRecordsAsync(Patient!.Id, page: 1, pageSize: 50);
            _records     = result?.Items?.ToList() ?? [];
            _recordCount = result?.TotalCount ?? 0;
        }
        catch { _records = []; }
        finally { _recordsLoading = false; }
    }

    private async Task SaveRecord()
    {
        _recordError = null;
        if (string.IsNullOrWhiteSpace(_rec.Reason))
        { _recordError = "El motivo es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(_rec.Diagnosis))
        { _recordError = "El diagnóstico es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(_rec.Treatment))
        { _recordError = "El tratamiento es obligatorio."; return; }

        if (DateTime.TryParse(_recDateStr, out var d))  _rec.Date = d;
        if (DateOnly.TryParseExact(_recNextStr, "yyyy-MM-dd", out var nv)) _rec.NextVisitDate = nv;

        _savingRecord = true;
        try
        {
            await PatientApi.AddRecordAsync(Patient!.Id, _rec);
            _showRecordForm = false;
            _rec = new();
            _recDateStr = DateTime.Today.ToString("yyyy-MM-dd");
            _recNextStr = "";
            await LoadRecordsAsync();
        }
        catch (Exception ex) { _recordError = ex.Message; }
        finally { _savingRecord = false; }
    }

    // ── Misc ────────────────────────────────────────────────────

    private async Task Close()
    {
        _referenceLog = null;   // limpia el panel al cerrar el modal
        await OnClose.InvokeAsync();
    }

    private static string AgeLabel(DateOnly birthDate)
    {
        var today  = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - birthDate.Year) * 12 + (today.Month - birthDate.Month);
        if (today.Day < birthDate.Day) months--;
        months = Math.Max(0, months);
        if (months < 12) return months == 1 ? "1 mes" : $"{months} meses";
        var years = months / 12;
        return years == 1 ? "1 año" : $"{years} años";
    }

    // ── Vacunas ─────────────────────────────────────────────────

    private async Task LoadVaccinationsAsync()
    {
        if (Patient == null) return;
        _vaccRecords        = await VaccApi.ListByPatientAsync(Patient.Id);
        _vaccineDefinitions = await VaccApi.ListDefinitionsAsync();
        _vaccineCount       = _vaccRecords.Count;
    }

    private async Task SaveVaccinationAsync()
    {
        if (Patient == null) return;
        _vaccError  = null;
        _vaccSaving = true;

        try
        {
            if (_vaccReq.VaccineDefinitionId == Guid.Empty)
            { _vaccError = "Selecciona una vacuna."; return; }

            if (string.IsNullOrEmpty(_vaccReq.AdministeredAt))
            { _vaccError = "La fecha de aplicación es obligatoria."; return; }

            var result = await VaccApi.RegisterAsync(Patient.Id, _vaccReq);
            if (result is null)
            { _vaccError = "No se pudo registrar la vacunación."; return; }

            _showVaccineForm = false;
            _vaccReq         = new() { AdministeredAt = DateTime.Today.ToString("yyyy-MM-dd") };
            await LoadVaccinationsAsync();
        }
        finally { _vaccSaving = false; }
    }

    private async Task DeleteVaccinationAsync(Guid recordId)
    {
        if (Patient == null) return;
        await VaccApi.DeleteAsync(Patient.Id, recordId);
        await LoadVaccinationsAsync();
    }
}
