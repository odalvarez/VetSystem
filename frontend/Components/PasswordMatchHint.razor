@* Bocadillo flotante que indica si las contraseñas coinciden.
   Desaparece cuando coinciden (estado correcto), igual que PasswordStrength. *@

@if (!string.IsNullOrEmpty(Confirm) && !Match)
{
    <div class="pwd-bubble-wrap">
        <div class="pwd-bubble">
            <div class="pwd-bubble-tip"></div>
            <div class="pwd-rules">
                <div class="pwd-rule fail">
                    <span class="pwd-rule-icon">○</span>
                    Las contraseñas no coinciden
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Password { get; set; } = "";
    [Parameter] public string Confirm  { get; set; } = "";

    private bool Match => Password == Confirm;
}
