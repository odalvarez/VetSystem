@* Campo etiqueta/valor para la historia clínica *@
@if (!string.IsNullOrWhiteSpace(Value))
{
    <div style="margin-bottom:4px">
        <span style="font-size:.75rem;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.04em">@Label: </span>
        <span style="font-size:.875rem">@Value</span>
    </div>
}

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Value { get; set; }
}
