@* Modal para editar los datos de una mascota existente.
   Disponible para cualquier rol autenticado (el backend también lo permite).
   La especie no es editable: cambiarla alteraría la identidad del animal. *@
@inject PatientApiClient PatientApi

@if (Visible && Patient != null)
{
    <div class="modal-overlay">
        <div class="modal-box" style="max-width:560px" tabindex="-1" @ref="_ref" @onkeydown="HandleKey" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">✏️ Editar mascota</span>
                <button class="btn-close" @onclick="Close">✕</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                @* Nombre y raza *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control @(_submitted && string.IsNullOrWhiteSpace(_req.Name) ? "invalid" : "")"
                               @bind="_req.Name" placeholder="Nombre de la mascota" />
                        @if (_submitted && string.IsNullOrWhiteSpace(_req.Name))
                        { <div class="validation-message">Campo requerido.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Raza *</label>
                        <input class="form-control @(_submitted && string.IsNullOrWhiteSpace(_req.Breed) ? "invalid" : "")"
                               @bind="_req.Breed" placeholder="Raza" />
                        @if (_submitted && string.IsNullOrWhiteSpace(_req.Breed))
                        { <div class="validation-message">Campo requerido.</div> }
                    </div>
                </div>

                @* Especie (solo lectura) y Sexo *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Especie</label>
                        <input class="form-control" value="@(string.IsNullOrEmpty(Patient.SpeciesName) ? Patient.Species : Patient.SpeciesName)" disabled />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sexo *</label>
                        <select class="form-control" @bind="_req.Sex">
                            <option value="male">Macho</option>
                            <option value="female">Hembra</option>
                        </select>
                    </div>
                </div>

                @* Fecha de nacimiento aproximada, peso y edad calculada *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Fecha de nac. aproximada *</label>
                        <input type="date" class="form-control"
                               value="@_req.BirthDate.ToString("yyyy-MM-dd")"
                               max="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")"
                               @oninput="HandleBirthDate" />
                        <div class="form-hint">Edad calculada: <strong>@AgeLabel(_req.BirthDate)</strong></div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Peso (kg) *</label>
                        <input type="number" step="0.01" min="0.01" max="999.99" class="form-control"
                               @bind="_req.WeightKg" />
                    </div>
                </div>

                @* Color y microchip *@
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <input class="form-control" @bind="_req.Color" placeholder="Ej: negro, blanco…" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Microchip</label>
                        <input class="form-control" @bind="_req.MicrochipNumber" placeholder="Número de microchip" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="Close" disabled="@_saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block"></span> }
                    else { <span>Guardar cambios</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool            Visible  { get; set; }
    [Parameter] public PatientResponse? Patient  { get; set; }
    [Parameter] public EventCallback   OnSaved  { get; set; }
    [Parameter] public EventCallback   OnClose  { get; set; }

    private UpdatePatientRequest _req       = new();
    private bool                 _submitted = false;
    private bool                 _saving    = false;
    private string?              _error;
    private ElementReference     _ref;
    private bool                 _prevVisible;

    protected override void OnParametersSet()
    {
        if (Visible && Patient != null)
        {
            // Precarga los valores actuales cada vez que se abre el modal con un paciente
            _req = new UpdatePatientRequest
            {
                Name            = Patient.Name,
                Breed           = Patient.Breed,
                BirthDate       = Patient.BirthDate,
                Sex             = Patient.Sex,
                WeightKg        = Patient.WeightKg,
                Color           = Patient.Color,
                MicrochipNumber = Patient.MicrochipNumber
            };
            _submitted = false;
            _error     = null;
        }
    }

    private void HandleBirthDate(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            _req.BirthDate = d;
    }

    private async Task Save()
    {
        _submitted = true;
        _error     = null;

        if (string.IsNullOrWhiteSpace(_req.Name) || string.IsNullOrWhiteSpace(_req.Breed)) return;
        if (_req.WeightKg <= 0) { _error = "El peso debe ser mayor que cero."; return; }

        _saving = true;
        try
        {
            await PatientApi.UpdateAsync(Patient!.Id, _req);
            await OnSaved.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await Close();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_prevVisible)
            await _ref.FocusAsync();
        _prevVisible = Visible;
    }

    // Muestra la edad en meses si es menor de 1 año, o en años si ya los tiene
    private static string AgeLabel(DateOnly birthDate)
    {
        var today  = DateOnly.FromDateTime(DateTime.Today);
        var months = (today.Year - birthDate.Year) * 12 + (today.Month - birthDate.Month);
        if (today.Day < birthDate.Day) months--;
        months = Math.Max(0, months);
        if (months < 12)
            return months == 1 ? "1 mes" : $"{months} meses";
        var years = months / 12;
        return years == 1 ? "1 año" : $"{years} años";
    }

}
