@* Modal que el veterinario usa para agregar un registro clínico a un paciente *@
@inject PatientApiClient PatientApi

@if (Visible)
{
    <div class="modal-overlay">
        <div class="modal-box" tabindex="-1" @ref="_modalRef" @onkeydown="HandleKeyDown" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">➕ Nuevo registro clínico — @PatientName</span>
                <button class="btn-close" @onclick="Close">✕</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Fecha de consulta *</label>
                        <input type="date" class="form-control"
                               max="@_todayStr"
                               value="@_dateStr"
                               @oninput="e => _dateStr = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Próxima visita</label>
                        <input type="date" class="form-control"
                               min="@_minNextVisitStr"
                               value="@_nextVisitStr"
                               @oninput="e => _nextVisitStr = e.Value?.ToString() ?? string.Empty" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Motivo de la consulta *</label>
                    <input class="form-control @(_submitted && string.IsNullOrWhiteSpace(_request.Reason) ? "invalid" : "")"
                           @bind="_request.Reason" placeholder="Ej. Revisión anual, vómitos, etc." />
                    @if (_submitted && string.IsNullOrWhiteSpace(_request.Reason))
                    {
                        <div class="validation-message">El motivo es obligatorio.</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">Diagnóstico *</label>
                    <input class="form-control @(_submitted && string.IsNullOrWhiteSpace(_request.Diagnosis) ? "invalid" : "")"
                           @bind="_request.Diagnosis" placeholder="Ej. Gastritis aguda" />
                    @if (_submitted && string.IsNullOrWhiteSpace(_request.Diagnosis))
                    {
                        <div class="validation-message">El diagnóstico es obligatorio.</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">Tratamiento *</label>
                    <textarea class="form-control @(_submitted && string.IsNullOrWhiteSpace(_request.Treatment) ? "invalid" : "")"
                              rows="3" @bind="_request.Treatment"
                              placeholder="Describe el tratamiento indicado…"></textarea>
                    @if (_submitted && string.IsNullOrWhiteSpace(_request.Treatment))
                    {
                        <div class="validation-message">El tratamiento es obligatorio.</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">Notas adicionales</label>
                    <textarea class="form-control" rows="2" @bind="_request.Notes"
                              placeholder="Observaciones, seguimiento, etc."></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Peso actual (kg)</label>
                        <input type="number" step="0.1" min="0" class="form-control"
                               @bind="_request.WeightKg" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Temperatura (°C)</label>
                        <input type="number" step="0.1" min="35" max="42" class="form-control"
                               @bind="_request.TemperatureCelsius" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="Close" disabled="@_saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving) { <span class="spinner spinner-sm"></span> }
                    else { <span>Guardar registro</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public Guid PatientId { get; set; }
    [Parameter] public string PatientName { get; set; } = "";
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private CreateClinicalRecordRequest _request         = new();
    private string                       _dateStr         = DateTime.Today.ToString("yyyy-MM-dd");
    private string                       _nextVisitStr    = "";
    private string                       _todayStr        = DateTime.Today.ToString("yyyy-MM-dd");
    private string                       _minNextVisitStr = DateTime.Today.AddDays(1).ToString("yyyy-MM-dd");
    private ElementReference             _modalRef;
    private bool                         _submitted;
    private bool                         _saving;
    private string?                      _error;
    private bool                         _prevVisible;

    // Resetea el formulario cada vez que el modal se abre
    protected override void OnParametersSet()
    {
        if (Visible)
        {
            _request      = new();
            _dateStr      = DateTime.Today.ToString("yyyy-MM-dd");
            _nextVisitStr = "";
            _submitted    = false;
            _error        = null;
        }
    }

    private async Task Save()
    {
        if (DateTime.TryParse(_dateStr, out var d))
            _request.Date = d;

        if (DateOnly.TryParseExact(_nextVisitStr, "yyyy-MM-dd", out var nv))
            _request.NextVisitDate = nv;

        _submitted = true;
        if (string.IsNullOrWhiteSpace(_request.Reason)    ||
            string.IsNullOrWhiteSpace(_request.Diagnosis) ||
            string.IsNullOrWhiteSpace(_request.Treatment))
            return;

        _saving = true;
        _error = null;

        try
        {
            await PatientApi.AddRecordAsync(PatientId, _request);
            await OnSaved.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await Close();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_prevVisible)
            await _modalRef.FocusAsync();
        _prevVisible = Visible;
    }
}
