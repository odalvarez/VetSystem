@* Selector compacto de indicativo de país + campo de número local.
   Emite el número completo (indicativo + dígitos) via ValueChanged.
   Soporta pre-población: si Value llega con un indicativo conocido lo detecta automáticamente. *@

<div class="phone-field">
    <div class="phone-prefix" @onclick="TogglePicker">
        +@_dial
        <span class="phone-prefix-arrow">▾</span>
        @if (_open)
        {
            <div class="phone-picker-overlay" @onclick="ClosePickerOverlay" @onclick:stopPropagation></div>
            <div class="phone-picker-dropdown" @onclick:stopPropagation>
                <input class="phone-picker-search"
                       @bind="_search" @bind:event="oninput"
                       placeholder="Buscar país…" />
                <div class="phone-picker-list">
                    @foreach (var c in Filtered)
                    {
                        <button class="phone-picker-option" type="button" @onclick="() => Pick(c)">
                            <span class="phone-picker-iso">@c.Iso</span>
                            <span class="phone-picker-name">@c.Name</span>
                            <span class="phone-picker-dial">+@c.Dial</span>
                        </button>
                    }
                </div>
            </div>
        }
    </div>
    <input class="phone-number"
           value="@_local"
           @oninput="HandleLocal"
           placeholder="@Placeholder"
           inputmode="tel" />
</div>

@code {
    // ── Parámetros ────────────────────────────────────────────────────────────

    /// Número completo que se emite al padre (indicativo + número sin espacios).
    [Parameter] public string  Value        { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string  Placeholder  { get; set; } = "3001234567";

    // ── Estado interno ────────────────────────────────────────────────────────

    private string _dial   = "57";   // indicativo activo (Colombia por defecto)
    private string _local  = "";     // número local sin indicativo
    private bool   _open   = false;
    private string _search = "";

    private string _lastValue = "";  // evita re-parsear si Value no cambió

    // ── Ciclo de vida ─────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        // Si llega un Value externo distinto al que nosotros emitimos, intentamos parsearlo
        if (Value == _lastValue) return;
        _lastValue = Value;

        if (string.IsNullOrWhiteSpace(Value))
        {
            _local = "";
            return;
        }

        // Buscamos el indicativo más largo que sea prefijo del valor
        var stripped = Value.TrimStart('+');
        var match = AllCountries
            .OrderByDescending(c => c.Dial.Length)
            .FirstOrDefault(c => stripped.StartsWith(c.Dial));

        if (match is not null)
        {
            _dial  = match.Dial;
            _local = stripped[match.Dial.Length..];
        }
        else
        {
            _local = stripped;
        }
    }

    // ── Interacciones ─────────────────────────────────────────────────────────

    private void TogglePicker() { _open = !_open; _search = ""; }
    private void ClosePickerOverlay() { _open = false; _search = ""; }

    private async Task Pick(Country c)
    {
        _dial  = c.Dial;
        _open  = false;
        _search = "";
        await Emit();
    }

    private async Task HandleLocal(ChangeEventArgs e)
    {
        _local = e.Value?.ToString() ?? "";
        await Emit();
    }

    private async Task Emit()
    {
        var digits = System.Text.RegularExpressions.Regex.Replace(_local, @"\D", "");
        var full   = string.IsNullOrEmpty(digits) ? "" : _dial + digits;
        _lastValue = full;
        await ValueChanged.InvokeAsync(full);
    }

    // ── Búsqueda ──────────────────────────────────────────────────────────────

    private IEnumerable<Country> Filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? AllCountries
            : AllCountries.Where(c =>
                c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                c.Dial.StartsWith(_search) ||
                c.Iso.Contains(_search, StringComparison.OrdinalIgnoreCase));

    // ── Modelo ────────────────────────────────────────────────────────────────

    private record Country(string Iso, string Name, string Dial);

