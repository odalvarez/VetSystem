@* Bocadillo flotante de requisitos; desaparece cuando todos están satisfechos.
   El contenedor usa height:0 + overflow:visible para no desplazar el layout. *@
@if (!string.IsNullOrEmpty(Password) && !IsValid(Password))
{
    <div class="pwd-bubble-wrap">
        <div class="pwd-bubble">
            <div class="pwd-bubble-tip"></div>
            <div class="pwd-bubble-title">Requisitos de contraseña</div>
            <div class="pwd-rules">
                <div class="pwd-rule @(Password.Length >= 6 ? "ok" : "fail")">
                    <span class="pwd-rule-icon">@(Password.Length >= 6 ? "✓" : "○")</span>
                    Mínimo 6 caracteres
                </div>
                <div class="pwd-rule @(HasLetter ? "ok" : "fail")">
                    <span class="pwd-rule-icon">@(HasLetter ? "✓" : "○")</span>
                    Al menos una letra
                </div>
                <div class="pwd-rule @(HasUpper ? "ok" : "fail")">
                    <span class="pwd-rule-icon">@(HasUpper ? "✓" : "○")</span>
                    Al menos una mayúscula
                </div>
                <div class="pwd-rule @(HasDigit ? "ok" : "fail")">
                    <span class="pwd-rule-icon">@(HasDigit ? "✓" : "○")</span>
                    Al menos un número
                </div>
                <div class="pwd-rule @(HasSpecial ? "ok" : "fail")">
                    <span class="pwd-rule-icon">@(HasSpecial ? "✓" : "○")</span>
                    Un carácter especial (!@@#$%...)
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Password { get; set; } = "";

    private bool HasLetter  => Password.Any(char.IsLetter);
    private bool HasUpper   => Password.Any(char.IsUpper);
    private bool HasDigit   => Password.Any(char.IsDigit);
    private bool HasSpecial => Password.Any(c => !char.IsLetterOrDigit(c));

    public static bool IsValid(string p) =>
        p.Length >= 6 &&
        p.Any(char.IsLetter) &&
        p.Any(char.IsUpper) &&
        p.Any(char.IsDigit) &&
        p.Any(c => !char.IsLetterOrDigit(c));
}
