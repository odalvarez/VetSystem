@* Modal para que el veterinario registre una nueva mascota eligiendo al propietario *@
@inject PatientApiClient PatientApi
@inject AuthApiClient    AuthApi
@inject SpeciesApiClient SpeciesApi

@if (Visible)
{
    <div class="modal-overlay">
        <div class="modal-box" tabindex="-1" @ref="_modalRef" @onkeydown="HandleKeyDown" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">🐾 Registrar mascota</span>
                <button class="btn-close" @onclick="Close">✕</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <div class="form-group">
                    <label class="form-label">Propietario *</label>
                    @if (_owners == null)
                    {
                        <LoadingSpinner Message="Cargando propietarios…" />
                    }
                    else
                    {
                        <div style="position:relative">
                            <input class="form-control @(_submitted && _selectedOwner == null ? "invalid" : "")"
                                   placeholder="Buscar por nombre, apellido o correo…"
                                   value="@_ownerSearch"
                                   @oninput="OnOwnerSearch"
                                   @onfocus="() => _showOwnerDrop = true"
                                   @onblur="HideOwnerDrop"
                                   autocomplete="off" />

                            @if (_showOwnerDrop && _ownerResults.Any())
                            {
                                <div style="position:absolute;z-index:999;width:100%;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,.12);max-height:220px;overflow-y:auto;margin-top:2px">
                                    @foreach (var o in _ownerResults)
                                    {
                                        <div style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--color-border-light)"
                                             @onmousedown="() => SelectOwner(o)">
                                            <div style="font-weight:600;font-size:.9rem">@o.FullName</div>
                                            <div style="font-size:.78rem;color:var(--color-text-muted)">@o.Email @(string.IsNullOrEmpty(o.Phone) ? "" : $"· {o.Phone}")</div>
                                        </div>
                                    }
                                </div>
                            }
                            @if (_showOwnerDrop && !string.IsNullOrWhiteSpace(_ownerSearch) && !_ownerResults.Any())
                            {
                                <div style="position:absolute;z-index:999;width:100%;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:12px 14px;color:var(--color-text-muted);font-size:.85rem;margin-top:2px">
                                    Sin resultados para "<strong>@_ownerSearch</strong>"
                                </div>
                            }
                        </div>
                        @if (_submitted && _selectedOwner == null)
                        { <div class="validation-message">Selecciona un propietario.</div> }
                    }
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control @Cls(_request.Name)"
                               @bind="_request.Name" placeholder="Nombre de la mascota" />
                        @if (_submitted && string.IsNullOrWhiteSpace(_request.Name))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Especie *</label>
                        @if (_species == null)
                        {
                            <select class="form-control" disabled><option>Cargando…</option></select>
                        }
                        else
                        {
                            <select class="form-control @Cls(_request.Species)" @bind="_request.Species">
                                <option value="">— Selecciona —</option>
                                @foreach (var s in _species)
                                {
                                    <option value="@s.Slug">@s.Name</option>
                                }
                            </select>
                        }
                        @if (_submitted && string.IsNullOrWhiteSpace(_request.Species))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Raza *</label>
                        <input class="form-control @Cls(_request.Breed)" @bind="_request.Breed" placeholder="Raza o mestizo" />
                        @if (_submitted && string.IsNullOrWhiteSpace(_request.Breed))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <input class="form-control" @bind="_request.Color" placeholder="Color del pelaje" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Sexo *</label>
                        <select class="form-control @Cls(_request.Sex)" @bind="_request.Sex">
                            <option value="">— Selecciona —</option>
                            <option value="Male">Macho</option>
                            <option value="Female">Hembra</option>
                        </select>
                        @if (_submitted && string.IsNullOrWhiteSpace(_request.Sex))
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Edad *</label>
                        <div style="display:flex;gap:8px;align-items:center">
                            <input type="number"
                                   min="1"
                                   max="@(_ageUnit == "months" ? 11 : 40)"
                                   class="form-control @(_submitted && _ageValue <= 0 ? "invalid" : "")"
                                   style="flex:1"
                                   @bind="_ageValue"
                                   @bind:after="ClampAge" />
                            <select class="form-control" style="flex:0 0 110px" @bind="_ageUnit" @bind:after="ClampAge">
                                <option value="years">Años</option>
                                <option value="months">Meses</option>
                            </select>
                        </div>
                        @if (_submitted && _ageValue <= 0)
                        { <div class="validation-message">Obligatorio.</div> }
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Peso (kg) *</label>
                        <input type="number" step="0.1" min="0.01"
                               class="form-control @(_submitted && _request.WeightKg <= 0 ? "invalid" : "")"
                               @bind="_request.WeightKg" />
                        @if (_submitted && _request.WeightKg <= 0)
                        { <div class="validation-message">Debe ser mayor a cero.</div> }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Microchip</label>
                        <input class="form-control" @bind="_request.MicrochipNumber"
                               placeholder="Número de microchip" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="Close" disabled="@_saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving) { <span class="spinner spinner-sm"></span> }
                    else { <span>Registrar mascota</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private List<SpeciesResponse>? _species;
    private List<OwnerSummary>?    _owners;
    private OwnerSummary?          _selectedOwner;
    private List<OwnerSummary>   _ownerResults = [];
    private string               _ownerSearch  = "";
    private bool                 _showOwnerDrop;
    private CreatePatientRequest _request  = new();
    private int                  _ageValue = 0;
    private string               _ageUnit  = "years";
    private ElementReference     _modalRef;
    private bool                 _submitted;
    private bool                 _saving;
    private string?              _error;
    private bool                 _prevVisible;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && _owners == null)
        {
            await Task.WhenAll(
                AuthApi.GetOwnersAsync().ContinueWith(t => _owners = t.Result),
                SpeciesApi.GetAllAsync().ContinueWith(t => _species = t.Result));
        }
        else if (!Visible)
        {
            _owners = null; _selectedOwner = null; _species = null;
            _ownerSearch = ""; _ownerResults = []; _showOwnerDrop = false;
            _request = new(); _ageValue = 0; _ageUnit = "years";
            _submitted = false; _error = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_prevVisible)
            await _modalRef.FocusAsync();
        _prevVisible = Visible;
    }

    private void OnOwnerSearch(ChangeEventArgs e)
    {
        _ownerSearch   = e.Value?.ToString() ?? "";
        _selectedOwner = null;
        _showOwnerDrop = true;

        if (string.IsNullOrWhiteSpace(_ownerSearch))
        {
            _ownerResults = [];
            return;
        }

        var q = _ownerSearch.Trim().ToLowerInvariant();
        _ownerResults = (_owners ?? [])
            .Where(o => o.FullName.ToLowerInvariant().Contains(q)
                     || o.Email.ToLowerInvariant().Contains(q)
                     || (o.Phone ?? "").Contains(q))
            .Take(8)
            .ToList();
    }

    private void SelectOwner(OwnerSummary owner)
    {
        _selectedOwner = owner;
        _ownerSearch   = owner.FullName;
        _ownerResults  = [];
        _showOwnerDrop = false;
    }

    // onblur se dispara antes que onmousedown del item; el delay permite que SelectOwner se ejecute primero
    private async Task HideOwnerDrop()
    {
        await Task.Delay(150);
        _showOwnerDrop = false;
    }

    private void ClampAge()
    {
        if (_ageUnit == "months" && _ageValue > 11) _ageValue = 11;
        if (_ageValue < 0) _ageValue = 0;
    }

    private async Task Save()
    {
        _request.BirthDate = _ageUnit == "months"
            ? DateOnly.FromDateTime(DateTime.Today.AddMonths(-_ageValue))
            : DateOnly.FromDateTime(DateTime.Today.AddYears(-_ageValue));

        _submitted = true;

        if (_selectedOwner == null                        ||
            string.IsNullOrWhiteSpace(_request.Name)    ||
            string.IsNullOrWhiteSpace(_request.Species) ||
            string.IsNullOrWhiteSpace(_request.Breed)   ||
            string.IsNullOrWhiteSpace(_request.Sex)     ||
            _ageValue <= 0                               ||
            _request.WeightKg <= 0)
            return;

        _request.OwnerId    = _selectedOwner.Id;
        _request.OwnerName  = _selectedOwner.FullName;
        _request.OwnerPhone = _selectedOwner.Phone;
        _request.OwnerEmail = _selectedOwner.Email;

        _saving = true;
        _error  = null;
        try
        {
            await PatientApi.CreateAsync(_request);
            await OnSaved.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await Close();
    }

    private string Cls(string? v) => _submitted && string.IsNullOrWhiteSpace(v) ? "invalid" : "";
}
